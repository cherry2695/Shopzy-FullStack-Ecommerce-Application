</main>

<!-- Back to top trigger script -->
<script>
  // Hero dynamic carousel sliders loop
  let activeSlide = 0;
  const slides = document.querySelectorAll('.hero-slide');

  function showSlide(idx) {
    if (slides.length === 0) return;
    slides.forEach((slide) => {
      slide.classList.remove('opacity-100', 'z-10');
      slide.classList.add('opacity-0', 'z-0');
    });
    activeSlide = (idx + slides.length) % slides.length;
    slides[activeSlide].classList.add('opacity-100', 'z-10');
    slides[activeSlide].classList.remove('opacity-0', 'z-0');
  }

  function nextSlide() { showSlide(activeSlide + 1); }
  function prevSlide() { showSlide(activeSlide - 1); }

  // Auto sliding interval (every 6 seconds)
  setInterval(nextSlide, 6000);

  // Flash Sale Timer calculations
  let timeInSecs = 13528; // Standard 3hr 45min count
  function updateCountdown() {
    timeInSecs--;
    if (timeInSecs <= 0) timeInSecs = 13528;
    const hrs = Math.floor(timeInSecs / 3600);
    const mins = Math.floor((timeInSecs % 3600) / 60);
    const secs = timeInSecs % 60;
    
    document.getElementById('timerHrs').innerText = hrs.toString().padStart(2, '0');
    document.getElementById('timerMins').innerText = mins.toString().padStart(2, '0');
    document.getElementById('timerSecs').innerText = secs.toString().padStart(2, '0');
  }
  setInterval(updateCountdown, 1000);

  // AJAX Quick Add to Cart Integration
  async function quickAddCart(productId) {
    <% if (!user) { %>
      window.location.href = `/login?redirect=${encodeURIComponent('/')}`;
      return;
    <% } else { %>
      try {
        const payload = new URLSearchParams();
        payload.append('productId', productId);
        payload.append('quantity', '1');

        const response = await fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: payload
        });

        if (response.redirected) {
          // Increment virtual badge quantity in layout header
          const badge = document.getElementById('cartBadgeCount');
          if (badge) {
            let count = parseInt(badge.innerText.trim()) || 0;
            badge.innerText = count + 1;
            badge.classList.add('scale-125');
            setTimeout(() => badge.classList.remove('scale-125'), 250);
          }
          triggerNotification('success', 'Item dispatched to your cart securely.');
        } else {
          triggerNotification('error', 'Unable to execute addToCart query.');
        }
      } catch (err) {
        triggerNotification('error', 'Connection offline.');
      }
    <% } %>
  }

  // Heart toggle wishlist trigger
  async function toggleHeart(btn, productId) {
    <% if (!user) { %>
      window.location.href = `/login?redirect=${encodeURIComponent('/')}`;
      return;
    <% } else { %>
      try {
        const response = await fetch('/wishlist/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId })
        });
        const r = await response.json();
        
        if (r.success) {
          const icon = btn.querySelector('i');
          if (r.action === 'added') {
            btn.classList.add('text-red-500');
            btn.classList.remove('text-gray-400');
            icon.setAttribute('fill', 'currentColor');
            triggerNotification('success', 'Added to your Wishlist!');
          } else {
            btn.classList.remove('text-red-500');
            btn.classList.add('text-gray-400');
            icon.removeAttribute('fill');
            triggerNotification('success', 'Removed from Wishlist.');
          }
          lucide.createIcons(); // Redraw Lucide state
        }
      } catch {
        triggerNotification('error', 'Connectivity failure.');
      }
    <% } %>
  }
</script>

<%- include('partials/footer') %>
