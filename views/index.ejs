              <a href="/products/<%= p.id || p._id %>" class="font-semibold text-gray-900 group-hover:text-amazon-orange transition text-sm truncate block"><%= p.title %></a>
              <div class="flex items-center text-amber-500 space-x-1.5 mt-1">
