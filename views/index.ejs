            </div>
            <button onclick="quickAddCart('<%= p.id || p._id %>')" class="h-8 w-8 rounded-full border border-gray-205 bg-amazon-gold hover:bg-amber-600 text-slate-900 flex items-center justify-center cursor-pointer transition">
              <i data-lucide="plus" class="w-4 h-4"></i>
            </button>
          </div>
        <% }) %>
      </div>
    </div>
