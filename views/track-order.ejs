<%- include('partials/header') %>

<main class="max-w-4xl mx-auto my-12 px-6 flex-grow flex flex-col justify-center select-none">
  <div class="bg-white rounded-2xl shadow-xl border border-gray-150 p-6 sm:p-10 relative overflow-hidden">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-gray-150 pb-6 mb-8 gap-4">
      <div>
        <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wide">SHIPMENT MOVEMENT MANAGER</p>
        <h2 class="text-2xl font-bold font-display text-gray-950 tracking-tight">Track Delivery Status</h2>
      </div>
      <div class="bg-gray-50 border border-gray-200 py-1.5 px-4 rounded-xl text-xs font-mono font-bold">
        #<%= order.orderId %>
      </div>
    </div>

    <!-- VISUAL LOGISTICS PROGRESS STEPPER BOARD -->
    <% 
      const statusesList = ['Pending', 'Confirmed', 'Packed', 'Shipped', 'Out For Delivery', 'Delivered'];
      const activeIdx = statusesList.indexOf(order.orderStatus);
    %>
    <div class="relative py-8 select-none">
      <!-- Background slider connector line -->
      <div class="absolute top-[52px] left-8 sm:left-12 right-8 sm:right-12 h-1 bg-gray-200"></div>
      <!-- Colored success progression connector line -->
      <div class="absolute top-[52px] left-8 sm:left-12 h-1 bg-gradient-to-r from-amazon-gold to-amazon-orange transition-all duration-750" 
           style="width: <%= activeIdx <= 0 ? '0%' : (activeIdx / (statusesList.length - 1)) * 80 %>%"></div>

      <!-- Steppers grid row -->
      <div class="grid grid-cols-6 relative z-10 text-center text-[9px] sm:text-[10px] font-black tracking-tight text-gray-400 uppercase">
        
        <!-- STEP 1: Pending -->
        <div class="flex flex-col items-center">
          <div class="h-10 w-10 sm:h-12 sm:w-12 rounded-full border-2 flex items-center justify-center mb-2.5 transition <%= activeIdx >= 0 ? 'bg-amazon-gold border-amazon-gold text-amazon-navy text-bold font-black ring-4 ring-amazon-gold/20' : 'bg-white border-gray-300 text-gray-400' %>">
            <i data-lucide="file-text" class="w-4.5 h-4.5 sm:w-5 sm:h-5"></i>
          </div>
          <span class="<%= activeIdx >= 0 ? 'text-amazon-navy font-bold' : '' %>">Placed</span>
        </div>

        <!-- STEP 2: Confirmed -->
        <div class="flex flex-col items-center">
          <div class="h-10 w-10 sm:h-12 sm:w-12 rounded-full border-2 flex items-center justify-center mb-2.5 transition <%= activeIdx >= 1 ? 'bg-amazon-gold border-amazon-gold text-amazon-navy ring-4 ring-amazon-gold/20' : 'bg-white border-gray-300 text-gray-400' %>">
            <i data-lucide="thumbs-up" class="w-4.5 h-4.5 sm:w-5 sm:h-5"></i>
          </div>
          <span class="<%= activeIdx >= 1 ? 'text-amazon-navy font-bold' : '' %>">Confirmed</span>
        </div>

        <!-- STEP 3: Packed -->
        <div class="flex flex-col items-center">
          <div class="h-10 w-10 sm:h-12 sm:w-12 rounded-full border-2 flex items-center justify-center mb-2.5 transition <%= activeIdx >= 2 ? 'bg-amazon-gold border-amazon-gold text-amazon-navy ring-4 ring-amazon-gold/20' : 'bg-white border-gray-300 text-gray-400' %>">
            <i data-lucide="package-open" class="w-4.5 h-4.5 sm:w-5 sm:h-5"></i>
          </div>
          <span class="<%= activeIdx >= 2 ? 'text-amazon-navy font-bold' : '' %>">Packed</span>
        </div>

        <!-- STEP 4: Shipped -->
        <div class="flex flex-col items-center">
          <div class="h-10 w-10 sm:h-12 sm:w-12 rounded-full border-2 flex items-center justify-center mb-2.5 transition <%= activeIdx >= 3 ? 'bg-amazon-gold border-amazon-gold text-amazon-navy ring-4 ring-amazon-gold/20' : 'bg-white border-gray-300 text-gray-400' %>">
            <i data-lucide="truck" class="w-4.5 h-4.5 sm:w-5 sm:h-5"></i>
          </div>
          <span class="<%= activeIdx >= 3 ? 'text-amazon-navy font-bold' : '' %>">Shipped</span>
        </div>

        <!-- STEP 5: Out For Delivery -->
        <div class="flex flex-col items-center">
          <div class="h-10 w-10 sm:h-12 sm:w-12 rounded-full border-2 flex items-center justify-center mb-2.5 transition <%= activeIdx >= 4 ? 'bg-amazon-gold border-amazon-gold text-amazon-navy ring-4 ring-amazon-gold/20' : 'bg-white border-gray-300 text-gray-400' %>">
            <i data-lucide="map-pinned" class="w-4.5 h-4.5 sm:w-5 sm:h-5"></i>
          </div>
          <span class="<%= activeIdx >= 4 ? 'text-amazon-navy font-bold' : '' %>">Out for Delivery</span>
        </div>

        <!-- STEP 6: Delivered -->
        <div class="flex flex-col items-center">
          <div class="h-10 w-10 sm:h-12 sm:w-12 rounded-full border-2 flex items-center justify-center mb-2.5 transition <%= activeIdx >= 5 ? 'bg-amazon-orange border-amazon-orange text-white ring-4 ring-amazon-orange/20 animate-pulse' : 'bg-white border-gray-300 text-gray-400' %>">
            <i data-lucide="home" class="w-4.5 h-4.5 sm:w-5 sm:h-5"></i>
          </div>
          <span class="<%= activeIdx >= 5 ? 'text-amazon-orange font-bold font-display' : '' %>">Delivered</span>
        </div>

      </div>
    </div>

    <!-- Detailed tracked data summaries -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-gray-200 pt-8 mt-4 text-xs font-semibold text-gray-650">
      <div class="space-y-2">
        <h4 class="font-bold text-gray-950 uppercase text-[10px] tracking-wider leading-none">Shipping Destination address</h4>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 space-y-0.5">
          <p class="font-bold text-gray-950"><%= order.shippingAddress.fullName %></p>
          <p class="text-gray-500"><%= order.shippingAddress.addressLine1 %></p>
          <% if (order.shippingAddress.addressLine2) { %>
            <p class="text-gray-500"><%= order.shippingAddress.addressLine2 %></p>
          <% } %>
          <p class="text-gray-500"><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.postalCode %></p>
          <p class="text-gray-901 mt-1 font-semibold leading-snug">Estimated logistics dispatch: <strong><%= order.deliveryOption %> speed Delivery</strong></p>
        </div>
      </div>

      <div class="space-y-2">
        <h4 class="font-bold text-gray-950 uppercase text-[10px] tracking-wider leading-none">Order Invoice items</h4>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 space-y-2.5 max-h-[150px] overflow-y-auto">
          <% order.items.forEach(item => { %>
            <div class="flex justify-between items-center text-[11px]">
              <span class="truncate block max-w-56 text-gray-800"><%= item.title %></span>
              <span class="font-mono text-gray-950 font-black">x<%= item.quantity %></span>
            </div>
          <% }) %>
          <hr class="border-gray-200">
          <div class="flex justify-between font-bold text-gray-950">
            <span>Bill Value (Total)</span>
            <span class="font-mono">$<%= order.pricing.total %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Print info / Action button row -->
    <div class="mt-8 border-t border-gray-150 pt-6 flex justify-center items-center">
      <a href="/orders" class="px-6 py-2.5 bg-amazon-gold hover:bg-amber-600 text-amazon-navy text-xs font-black rounded-lg transition shadow flex items-center">
        <i data-lucide="arrow-left" class="w-4 h-4 mr-1"></i> Back to Orders Registry
      </a>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
