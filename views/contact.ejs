<%- include('partials/header') %>

<!-- Success flashing metrics -->
<% if (typeof successMsg !== 'undefined' && successMsg) { %>
  <script>window.addEventListener('load', () => triggerNotification('success', '<%= successMsg %>'));</script>
<% } %>

<main class="max-w-4xl mx-auto my-12 px-6 flex-grow select-none">
  <div class="bg-white rounded-2xl shadow-xl border border-gray-150 p-6 sm:p-10 relative overflow-hidden">
    
    <!-- Header title -->
    <div class="border-b border-gray-150 pb-6 mb-8 text-center sm:text-left">
      <h2 class="text-3xl font-extrabold font-display text-gray-950 tracking-tight flex items-center justify-center sm:justify-start">
        <i data-lucide="headphones" class="w-8 h-8 mr-2 text-amazon-gold animate-bounce"></i> Help & Support Center
      </h2>
      <p class="text-xs text-gray-500 mt-1">Stalemate billing questions or want to track packages? Raise a support ticket instantly.</p>
    </div>

    <!-- Contact splits layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      <!-- Contact Info sidebar (md:col-span-4) -->
      <div class="md:col-span-4 space-y-6 text-xs font-semibold text-gray-650">
        <div class="bg-gray-50 border border-gray-200 p-5 rounded-2xl space-y-4">
          <h4 class="font-extrabold text-sm text-gray-950 border-b border-gray-100 pb-1.5">Direct Helpdesk</h4>
          
          <div class="space-y-3.5">
            <div class="flex items-start space-x-2">
              <i data-lucide="mail" class="w-4 h-4 text-amazon-gold mt-0.5"></i>
              <div>
                <p class="text-gray-400">EMAIL SUPPORT</p>
                <p class="text-gray-900 mt-0.5">helpdesk@shopzy.com</p>
              </div>
            </div>

            <div class="flex items-start space-x-2">
              <i data-lucide="phone-call" class="w-4 h-4 text-amazon-gold mt-0.5"></i>
              <div>
                <p class="text-gray-400">TELEPHONE HELPDESK</p>
                <p class="text-gray-900 mt-0.5">+91 1800-SHOPZY-HELP</p>
              </div>
            </div>

            <div class="flex items-start space-x-2">
              <i data-lucide="map-pin" class="w-4 h-4 text-amazon-gold mt-0.5"></i>
              <div>
                <p class="text-gray-400">HEADQUARTERS</p>
                <p class="text-gray-901 mt-0.5 leading-snug">Level 15, Cloud Run Towers, Silicon Valley, India</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 border border-gray-200 p-5 rounded-2xl relative overflow-hidden">
          <h4 class="font-bold text-sm text-gray-950 mb-1">Response Speed SLA</h4>
          <p class="text-gray-500 leading-normal font-sans">Our support analysts will review codebases, database models, and route transactions within 2-4 working hours flat.</p>
        </div>
      </div>

      <!-- Ticket form (md:col-span-8) -->
      <div class="md:col-span-8 bg-white border border-gray-205 rounded-2xl p-6 shadow-sm">
        <h4 class="font-extrabold text-gray-950 text-sm font-display mb-4">Raise Technical Ticket</h4>

        <form action="/contact" method="POST" class="space-y-4 text-xs font-semibold">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-gray-500 mb-1">Your Name</label>
              <input 
                type="text" 
                name="name" 
                required 
                value="<%= user ? user.name : '' %>"
                placeholder="Full Name" 
                class="w-full text-xs px-3.5 py-2.5 border rounded-lg focus:ring-1 focus:ring-amazon-gold focus:outline-none"
              />
            </div>

            <div>
              <label class="block text-gray-500 mb-1">Contact Email</label>
              <input 
                type="email" 
                name="email" 
                required 
                value="<%= user ? user.email : '' %>"
                placeholder="Name@domain.com" 
                class="w-full text-xs px-3.5 py-2.5 border rounded-lg focus:ring-1 focus:ring-amazon-gold focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label class="block text-gray-500 mb-1">Subject Matter Topic</label>
            <input 
              type="text" 
              name="subject" 
              required 
              placeholder="e.g. Broken package shipment logistics, Card decline issues" 
              class="w-full text-xs px-3.5 py-2.5 border rounded-lg focus:ring-1 focus:ring-amazon-gold focus:outline-none"
            />
          </div>

          <div>
            <label class="block text-gray-500 mb-1">Ticket Category</label>
            <select name="category" class="bg-gray-50 text-gray-805 border border-gray-200 rounded-lg p-2 text-xs w-full cursor-pointer focus:ring-1 focus:ring-amazon-gold">
              <option value="Billing">Billing, Invoices & Coupon Codes help</option>
              <option value="Delivery">Package Shipments tracking & Logistics delays</option>
              <option value="Registration">Profile Accounts registrations & PIN codes</option>
              <option value="Feedback">Commercial Feedbacks, Reviews, & Ratings suggestions</option>
              <option value="Technical">Broken user experience pages, web applet issues</option>
            </select>
          </div>

          <div>
            <label class="block text-gray-500 mb-1">Detailed Message/Issue Explanation</label>
            <textarea name="message" rows="5" required placeholder="Specify order references, transactions, and explicit statements to optimize helper checks..." class="w-full text-xs px-3.5 py-2 border rounded-lg focus:ring-1 focus:ring-amazon-gold focus:outline-none"></textarea>
          </div>

          <button type="submit" class="w-full py-3.5 bg-amazon-orange hover:bg-amazon-gold text-amazon-navy font-bold rounded-lg transition text-xs uppercase tracking-wider cursor-pointer shadow">
            Submit Customer Support Ticket
          </button>
        </form>
      </div>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
