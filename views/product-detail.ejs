<%- include('partials/header') %>

<!-- Alerts reviews toggle -->
<% if (typeof query !== 'undefined' && query.review_success) { %>
  <script>window.addEventListener('load', () => triggerNotification('success', 'Your review has been captured and compiled. Thank you!'));</script>
<% } %>

<main class="max-w-7xl mx-auto px-4 py-8 flex-grow space-y-12 select-none">
  
  <!-- BREADCRUMB INDICATORS -->
  <nav class="text-xs text-gray-500 font-semibold space-x-2">
    <a href="/" class="hover:text-amazon-orange">Home</a>
    <span>/</span>
    <a href="/products?category=<%= encodeURIComponent(product.category) %>" class="hover:text-amazon-orange"><%= product.category %></a>
    <span>/</span>
    <span class="text-gray-800"><%= product.title %></span>
  </nav>

  <!-- PRODUCT LAYOUT CORES: HERO GALLERY + INFORMATIONS -->
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-10">
    <!-- Image Gallery (lg:col-span-5) -->
    <div class="lg:col-span-5 space-y-4">
      <div class="bg-white border border-gray-200 rounded-2xl h-[350px] sm:h-[450px] flex items-center justify-center overflow-hidden p-6 shadow-sm relative zoom-container">
        <!-- Floating Zoom hover effect simulated via classes -->
        <img 
          src="<%= product.images[0] %>" 
          alt="<%= product.title %>" 
          id="mainProductImg" 
          class="max-h-full max-w-full object-contain zoom-image" 
          referrerPolicy="no-referrer"
        />
      </div>

      <!-- Thumbnail Preview Strip -->
      <div class="flex space-x-2.5 overflow-x-auto py-1">
        <% product.images.forEach((img, idx) => { %>
          <button onclick="switchImage(this, '<%= img %>')" class="h-16 w-16 bg-white border <%= idx === 0 ? 'border-amazon-gold ring-2 ring-amazon-gold/25' : 'border-gray-250' %> rounded-lg flex-shrink-0 flex items-center justify-center p-1 cursor-pointer hover:border-amazon-gold transition">
            <img src="<%= img %>" alt="Thumbnail <%= idx %>" class="max-h-full max-w-full object-contain rounded" referrerPolicy="no-referrer" />
          </button>
        <% }) %>
      </div>
    </div>

    <!-- Product Details Content panel (lg:col-span-7) -->
    <div class="lg:col-span-7 space-y-6">
      <div class="space-y-2">
        <p class="text-xs font-mono font-bold text-amazon-orange uppercase tracking-wider"><%= product.brand %> BRAND ORIGINAL</p>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-950 font-display leading-tight tracking-tight"><%= product.title %></h1>
        
        <!-- Stars metric -->
        <div class="flex items-center space-x-3 mt-1">
          <div class="flex items-center text-amber-500 space-x-0.5">
            <% for(let i=1; i<=5; i++) { %>
              <i data-lucide="star" class="w-4 h-4 <%= i <= Math.round(product.rating) ? 'fill-current text-amber-500' : 'text-gray-300' %>"></i>
            <% } %>
          </div>
          <span class="text-xs text-gray-600 font-bold"><%= product.rating %> Average out of 5 stars</span>
          <span class="text-gray-300">|</span>
          <a href="#reviews" class="text-xs font-bold text-amazon-gold hover:underline"><%= reviews.length %> customer reviews</a>
        </div>
      </div>

      <hr class="border-gray-200">

      <!-- PRICING BENTO CARD -->
      <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm space-y-3">
        <div class="flex items-baseline space-x-3">
          <% if (product.discount > 0) { %>
            <span class="text-3xl font-black text-gray-900 font-mono">Rs. <%= Math.round(product.price * (1 - product.discount / 100)) %></span>
            <span class="text-sm text-gray-400 line-through font-mono">Rs. <%= product.price %></span>
            <span class="bg-red-50 text-red-650 text-xs font-black px-2.5 py-1 rounded-md animate-pulse font-display">SAVE <%= product.discount %>% OFF</span>
          <% } else { %>
            <span class="text-3xl font-black text-gray-900 font-mono">Rs. <%= product.price %></span>
          <% } %>
        </div>

        <p class="text-xs text-gray-500 leading-normal flex items-center">
          <i data-lucide="truck" class="w-4 h-4 mr-1 text-emerald-600"></i> Free Delivery on billing values exceeding Rs. 1500. Standard delivery applies otherwise.
        </p>

        <!-- Availability indicator -->
        <div class="text-xs font-bold mt-2">
          <% if (product.stock > 10) { %>
            <span class="text-emerald-600 flex items-center"><i data-lucide="check-circle" class="w-4 h-4 mr-1"></i> In Stock (<%= product.stock %> available)</span>
          <% } else if (product.stock > 0) { %>
            <span class="text-amber-600 flex items-center animate-pulse"><i data-lucide="alert-circle" class="w-4 h-4 mr-1"></i> Hurrying up! Only <%= product.stock %> items left in stock</span>
          <% } else { %>
            <span class="text-red-600 flex items-center"><i data-lucide="x-circle" class="w-4 h-4 mr-1"></i> Out of Stock (Restocking shortly)</span>
          <% } %>
        </div>
      </div>

      <!-- DESCRIPTIONS TEXT -->
      <div class="space-y-1.5">
        <h3 class="text-xs font-black text-gray-500 uppercase tracking-widest">Product Overview</h3>
        <p class="text-sm text-gray-650 leading-relaxed"><%= product.description %></p>
      </div>

      <!-- CART DISPATCH SYSTEM FORM -->
      <form action="/cart/add" method="POST" class="space-y-6">
        <input type="hidden" name="productId" value="<%= product.id || product._id %>" />

        <!-- Variants selection: Colors and Sizes -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-2">
          <!-- Colors -->
          <% if (product.colors && product.colors.length > 0) { %>
            <div class="space-y-2">
              <label class="block text-xs font-black text-gray-500 uppercase tracking-wider">Choose Finish Color</label>
              <div class="flex flex-wrap gap-2">
                <% product.colors.forEach((color, idx) => { %>
                  <label class="relative flex items-center justify-center cursor-pointer">
                    <input type="radio" name="color" value="<%= color %>" <%= idx === 0 ? 'checked' : '' %> class="peer sr-only" />
                    <span class="px-3.5 py-1.5 bg-gray-50 hover:bg-gray-100 text-xs font-semibold rounded-lg border border-gray-200 peer-checked:border-amazon-gold peer-checked:ring-2 peer-checked:ring-amazon-gold/25 transition block truncate">
                      <%= color %>
                    </span>
                  </label>
                <% }) %>
              </div>
            </div>
          <% } %>

          <!-- Sizes -->
          <% if (product.sizes && product.sizes.length > 0) { %>
            <div class="space-y-2">
              <label class="block text-xs font-black text-gray-500 uppercase tracking-wider font-display">Select Capacity / Variant Size</label>
              <div class="flex flex-wrap gap-2">
                <% product.sizes.forEach((size, idx) => { %>
                  <label class="relative flex items-center justify-center cursor-pointer">
                    <input type="radio" name="size" value="<%= size %>" <%= idx === 0 ? 'checked' : '' %> class="peer sr-only" />
                    <span class="px-3 py-1.5 bg-gray-50 hover:bg-gray-100 text-xs font-bold rounded-lg border border-gray-200 peer-checked:border-amazon-gold peer-checked:ring-2 peer-checked:ring-amazon-gold/25 transition block">
                      <%= size %>
                    </span>
                  </label>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Dispatch tools: Quantity + Add-to-cart buttons -->
        <div class="flex items-end space-x-4 pt-2">
          <!-- Quantity -->
          <div class="space-y-1.5">
            <label class="block text-xs font-black text-gray-500 uppercase tracking-wider">Quantity</label>
            <select name="quantity" class="bg-gray-100 text-gray-850 font-bold border border-gray-200 rounded-lg p-2.5 text-sm cursor-pointer focus:outline-none">
              <% for(let i=1; i<=Math.min(10, product.stock || 1); i++) { %>
                <option value="<%= i %>"><%= i %></option>
              <% } %>
            </select>
          </div>

          <!-- Actions -->
          <div class="flex-grow flex space-x-3.5">
            <% if (product.stock > 0) { %>
              <button type="submit" class="flex-grow bg-amazon-gold hover:bg-amber-600 text-slate-900 font-extrabold py-3 px-6 rounded-xl text-sm transition shadow flex items-center justify-center space-x-2 cursor-pointer transform hover:-translate-y-0.5 border border-transparent">
                <i data-lucide="shopping-cart" class="w-4.5 h-4.5"></i> <span>Add to Cart Basket</span>
              </button>
            <% } else { %>
              <button type="button" disabled class="flex-grow bg-gray-200 text-gray-400 font-bold py-3 px-6 rounded-xl text-sm cursor-not-allowed text-center">
                Sold Out currently
              </button>
            <% } %>

            <!-- Wishlist quick post button -->
            <button type="button" onclick="toggleDetailsWishlist('<%= product.id || product._id %>')" class="h-12 w-12 rounded-xl bg-white border border-gray-200 hover:border-red-400 text-gray-400 hover:text-red-500 flex items-center justify-center transition shadow-sm cursor-pointer">
              <i data-lucide="heart" class="w-5 h-5"></i>
            </button>
          </div>
        </div>
      </form>
    </div>
  </section>

  <!-- SPECIFICATIONS TABLE BOARD -->
  <section class="grid grid-cols-1 md:grid-cols-12 gap-8 border-t border-gray-200 pt-10">
    <div class="md:col-span-4 space-y-1.5">
      <h3 class="text-xl font-bold font-display text-gray-900 tracking-tight flex items-center">
        <i data-lucide="notebook-tabs" class="w-5 h-5 mr-1.5 text-gray-500"></i> Technical Specifications
      </h3>
      <p class="text-xs text-gray-500">Full detailed breakdown of standard components and certification lists.</p>
    </div>

    <!-- Table Grid -->
    <div class="md:col-span-8 bg-white border border-gray-150 rounded-2xl overflow-hidden shadow-sm">
      <table class="w-full text-sm text-left border-collapse">
        <tbody>
          <% if (product.specifications && product.specifications.length > 0) { %>
            <% product.specifications.forEach((spec, idx) => { %>
              <tr class="<%= idx % 2 === 0 ? 'bg-white' : 'bg-gray-50' %> border-b border-gray-100 last:border-0">
                <td class="px-6 py-3.5 font-bold text-gray-500 w-1/3 border-r border-gray-100"><%= spec.name %></td>
                <td class="px-6 py-3.5 text-gray-800 font-mono text-xs"><%= spec.value %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td class="px-6 py-4 text-center text-gray-400 font-semibold" colspan="2">No detailed specifications declared for this listing.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

  <!-- 15+ Yrs Exp Feature: FREQUENTLY BOUGHT TOGETHER BUNDLES -->
  <% if (bundles && bundles.length > 0) { %>
    <section class="bg-gray-100 border border-gray-200 rounded-2xl p-6 sm:p-8 space-y-6">
      <h3 class="text-lg font-bold font-display text-gray-950 flex items-center">
        <i data-lucide="layers" class="w-5 h-5 mr-1.5 text-amazon-gold"></i> Frequently Bought Together
      </h3>

      <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
        <!-- Scroll items chain -->
        <div class="flex flex-wrap items-center gap-4">
          <!-- Item 1 (Active) -->
          <div class="bg-white border border-gray-200 p-3 rounded-xl flex items-center justify-center h-20 w-20 relative shadow-sm">
            <img src="<%= product.images[0] %>" class="max-h-full max-w-full object-contain" referrerPolicy="no-referrer" />
          </div>

          <span class="text-xl font-bold font-display text-gray-400">+</span>

          <!-- Others -->
          <% bundles.forEach((b, idx) => { %>
            <div class="flex items-center space-x-4">
              <a href="/products/<%= b.id || b._id %>" class="bg-white border border-gray-200 p-3 rounded-xl flex items-center justify-center h-20 w-20 relative hover:shadow transition">
                <img src="<%= b.images[0] %>" class="max-h-full max-w-full object-contain" referrerPolicy="no-referrer" />
              </a>
              <% if (idx < bundles.length - 1) { %>
                <span class="text-xl font-bold font-display text-gray-400">+</span>
              <% } %>
            </div>
          <% }) %>
        </div>

        <!-- Pricing bundle details -->
        <% 
          const currentPrice = Math.round(product.price * (1 - product.discount/100));
          const b1Price = Math.round(bundles[0].price * (1 - bundles[0].discount/100));
          const b2Price = bundles[1] ? Math.round(bundles[1].price * (1 - bundles[1].discount/100)) : 0;
          const bundleTotal = currentPrice + b1Price + b2Price;
          const bundleTax = Math.round(bundleTotal * 0.1); // Bundle mock discounts
          const finalCost = bundleTotal - bundleTax;
        %>
        <div class="bg-white rounded-xl border border-gray-150 p-4 min-w-80 shadow-sm flex flex-col space-y-3">
          <div class="border-b border-gray-100 pb-2">
            <p class="text-xs text-gray-500 font-semibold uppercase leading-tight">Package Offer Total Price</p>
            <p class="text-2xl font-black text-gray-950 font-mono leading-none mt-1">
              $<%= finalCost %> <span class="text-xs text-green-600 font-bold font-display">(Save 10% Bundle Special!)</span>
            </p>
            <p class="text-[10px] text-gray-400 line-through leading-none mt-1">Reg Price: $<%= bundleTotal %></p>
          </div>
          
          <button onclick="addAllBundleItems(['<%= product.id || product._id %>', '<%= bundles[0].id || bundles[0]._id %>' <%= bundles[1] ? `, '${bundles[1].id || bundles[1]._id}'` : '' %>])" class="w-full py-2 bg-amazon-gold hover:bg-amazon-orange text-amazon-navy text-xs font-black rounded-lg shadow-sm transition uppercase tracking-wider cursor-pointer">
            Add Bundle package to Cart
          </button>
        </div>
      </div>
    </section>
  <% } %>

  <!-- REVIEWS MATRIX & FEEDBACK DIRECTORY -->
  <section id="reviews" class="grid grid-cols-1 lg:grid-cols-12 gap-8 border-t border-gray-200 pt-10">
    <!-- Left: summary score metrics (lg:col-span-4) -->
    <div class="lg:col-span-4 space-y-6">
      <h3 class="text-xl font-bold font-display text-gray-900 tracking-tight">Customer Feedbacks</h3>
      
      <!-- Average scorecard -->
      <div class="bg-white border border-gray-200 p-5 rounded-2xl shadow-sm text-center">
        <h4 class="text-4xl font-extrabold text-gray-900 font-mono"><%= product.rating %></h4>
        <div class="flex justify-center text-amber-500 space-x-1 mt-1 mb-2">
          <% for(let i=1; i<=5; i++) { %>
            <i data-lucide="star" class="w-4 h-4 <%= i <= Math.round(product.rating) ? 'fill-current' : 'text-gray-300' %>"></i>
          <% } %>
        </div>
        <p class="text-xs text-gray-500 font-semibold"><%= reviews.length %> Ratings compiled</p>
      </div>

      <!-- Add feedback box directly -->
      <div class="bg-white border border-gray-200 p-5 rounded-2xl shadow-sm space-y-4">
        <h4 class="font-bold text-gray-950 font-display text-sm">Write Review</h4>
        <% if (user) { %>
          <form action="/products/<%= product.id || product._id %>/review" method="POST" class="space-y-3.5">
            <div>
              <label class="block text-[11px] font-black text-gray-500 uppercase mb-1">Star Rating</label>
              <select name="rating" class="bg-gray-50 text-gray-805 border border-gray-200 rounded-lg p-2 text-xs w-full cursor-pointer focus:ring-1 focus:ring-amazon-gold">
                <option value="5">5 Stars (Excellent Product)</option>
                <option value="4">4 Stars (Highly Recommended)</option>
                <option value="3">3 Stars (Satisfactory Work)</option>
                <option value="2">2 Stars (Average qualities)</option>
                <option value="1">1 Star (Disappointed with purchase)</option>
              </select>
            </div>

            <div>
              <label class="block text-[11px] font-black text-gray-500 uppercase mb-1">Written Feedback</label>
              <textarea name="comment" rows="3" required placeholder="What did you like or dislike? How was the dynamic performance of the original product?" class="w-full text-xs px-3 py-2 border border-gray-200 rounded-lg focus:ring-1 focus:ring-amazon-gold focus:outline-none"></textarea>
            </div>

            <button type="submit" class="w-full py-2 bg-amazon-gold hover:bg-amber-600 text-amazon-navy text-xs font-black rounded-lg transition shadow-sm cursor-pointer">
              Submit Customer Review
            </button>
          </form>
        <% } else { %>
          <div class="bg-gray-50 rounded-lg p-4 text-center border border-dashed border-gray-300 text-xs text-gray-500">
            Please <a href="/login?redirect=<%= encodeURIComponent(`/products/${product._id || product.id}`) %>" class="font-bold text-amazon-gold hover:underline">Sign In account</a> to draft user reviews.
          </div>
        <% } %>
      </div>
    </div>

    <!-- Right: Feedback scroll matrix (lg:col-span-8) -->
    <div class="lg:col-span-8 space-y-4">
      <h3 class="text-sm font-black text-gray-500 uppercase tracking-widest mb-4">Customer Testimonials</h3>
      
      <% if (reviews.length === 0) { %>
        <div class="bg-gray-50 border border-dashed border-gray-300 rounded-2xl p-10 text-center text-gray-400 select-none text-xs font-semibold">
          No feedback reviews found for this catalog yet. Be the very first customer to submit ratings!
        </div>
      <% } else { %>
        <div class="space-y-4 max-h-[500px] overflow-y-auto pr-1">
          <% reviews.forEach(r => { %>
            <div class="bg-white border border-gray-155 rounded-2xl p-4 shadow-sm flex flex-col justify-between">
              <div>
                <div class="flex justify-between items-start mb-2">
                  <div class="flex items-center space-x-2">
                    <div class="h-6 w-6 bg-amazon-accent text-white font-black text-[10px] rounded-full flex items-center justify-center">
                      <%= r.userName.charAt(0).toUpperCase() %>
                    </div>
                    <span class="font-bold text-gray-800 text-xs truncate"><%= r.userName %></span>
                  </div>
                  <!-- Stars -->
                  <div class="flex items-center text-amber-500 space-x-0.5">
                    <% for(let i=1; i<=5; i++) { %>
                      <i data-lucide="star" class="w-3.5 h-3.5 <%= i <= r.rating ? 'fill-current' : 'text-gray-300' %>"></i>
                    <% } %>
                  </div>
                </div>
                <p class="text-sm text-gray-700 leading-relaxed font-sans mt-2"><%= r.comment %></p>
              </div>
              <div class="text-[10px] text-gray-400 text-right mt-3 font-semibold">
                Captured: <%= new Date(r.createdAt || Date.now()).toLocaleDateString() %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

</main>

<script>
  // Dynamic thumbnail switcher
  function switchImage(btn, imgUrl) {
    const mainImg = document.getElementById('mainProductImg');
    if (!mainImg) return;
    mainImg.src = imgUrl;

    // Reset buttons ring highlighting
    const siblingBtns = btn.parentNode.querySelectorAll('button');
    siblingBtns.forEach(b => {
      b.classList.remove('border-amazon-gold', 'ring-2', 'ring-amazon-gold/25');
      b.classList.add('border-gray-250');
    });

    btn.classList.add('border-amazon-gold', 'ring-2', 'ring-amazon-gold/25');
    btn.classList.remove('border-gray-250');
  }

  // Dual action multi-items adder bundle
  async function addAllBundleItems(pIdsArray) {
    <% if (!user) { %>
      window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname)}`;
      return;
    <% } %>

    try {
      triggerNotification('success', 'Syncing bundle transaction...');
      for (const pId of pIdsArray) {
        const payload = new URLSearchParams();
        payload.append('productId', pId);
        payload.append('quantity', '1');
        
        await fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: payload
        });
      }
      
      // Update global header quantities UI
      const badge = document.getElementById('cartBadgeCount');
      if (badge) {
        let count = parseInt(badge.innerText.trim()) || 0;
        badge.innerText = count + pIdsArray.length;
      }

      triggerNotification('success', 'Package offer items loaded securely. Redirecting to Cart...');
      setTimeout(() => { window.location.href = '/cart'; }, 1500);
    } catch {
      triggerNotification('error', 'Bundle processing timed out.');
    }
  }

  // Heart trigger wishlist toggle on details
  async function toggleDetailsWishlist(productId) {
    <% if (!user) { %>
      window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname)}`;
      return;
    <% } %>
    try {
      const response = await fetch('/wishlist/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId })
      });
      const r = await response.json();
      if (r.success) {
        triggerNotification('success', r.action === 'added' ? 'Product bookmarked in Wishlist!' : 'Removed from Wishlist.');
      }
    } catch {
      triggerNotification('error', 'Operation failed.');
    }
  }
</script>

<%- include('partials/footer') %>
