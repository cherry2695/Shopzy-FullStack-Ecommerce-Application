<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 py-12 flex-grow space-y-10 selection-none">
  
  <div class="space-y-1.5 border-b border-gray-200 pb-4">
    <h1 class="text-3xl font-bold font-display text-gray-950 tracking-tight flex items-center">
      <i data-lucide="git-compare" class="w-6 h-6 mr-2 text-amazon-gold"></i> Product Comparison Center
    </h1>
    <p class="text-xs text-gray-500">Cross-examine premium specifications, ratings, and pricing side-by-side.</p>
  </div>

  <% if (products.length === 0) { %>
    <!-- Empty table info -->
    <div class="bg-white rounded-2xl border border-gray-150 p-16 text-center shadow-sm select-none">
      <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 text-blue-600 mb-4">
        <i data-lucide="git-compare" class="w-6 h-6"></i>
      </div>
      <h3 class="text-lg font-bold text-gray-900 mb-1">Your Comparison Stack is Empty</h3>
      <p class="text-xs text-gray-500 max-w-sm mx-auto mb-6">Dispatch items directly from products search grids to explore side-by-side spec layouts.</p>
      <a href="/products" class="bg-amazon-gold text-amazon-navy text-xs font-black py-2.5 px-6 rounded-lg hover:bg-amazon-orange transition shadow">
        View Inventory Catalog
      </a>
    </div>
  <% } else { %>
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-x-auto">
      <table class="w-full text-sm text-left border-collapse min-w-[700px]">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-205">
            <th class="p-6 text-xs font-black text-gray-550 uppercase tracking-widest w-1/5 border-r border-gray-150">Attributes</th>
            <% products.forEach(p => { %>
              <th class="p-6 text-center select-none w-1/4 last:border-0 border-r border-gray-150 group">
                <div class="relative flex flex-col items-center">
                  <!-- Remove button -->
                  <button onclick="popFromComparisonList('<%= p.id || p._id %>')" class="absolute -top-3 -right-3 text-gray-400 hover:text-red-500 cursor-pointer p-1">
                    <i data-lucide="x" class="w-4 h-4"></i>
                  </button>
                  <img src="<%= p.images[0] %>" alt="<%= p.title %>" class="h-24 w-24 object-contain rounded mb-3" referrerPolicy="no-referrer" />
                  <p class="text-xs font-mono font-bold text-gray-400 leading-none uppercase mb-1"><%= p.brand %></p>
                  <a href="/products/<%= p.id || p._id %>" class="font-bold text-gray-950 hover:text-amazon-orange text-xs text-center line-clamp-2 leading-snug"><%= p.title %></a>
                </div>
              </th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <!-- Price -->
          <tr class="border-b border-gray-100 last:border-0">
            <td class="px-6 py-4 font-bold text-gray-500 bg-gray-50/50 border-r border-gray-100">Offer Price</td>
            <% products.forEach(p => { %>
              <td class="px-6 py-4 text-center font-mono font-black text-green-600 text-sm border-r border-gray-100 last:border-0">
                <% if (p.discount > 0) { %>
                  Rs. <%= Math.round(p.price * (1 - p.discount / 100)) %>
                  <span class="block text-[10px] text-gray-400 line-through leading-3 mt-0.5">Rs. <%= p.price %></span>
                <% } else { %>
                  Rs. <%= p.price %>
                <% } %>
              </td>
            <% }) %>
          </tr>

          <!-- Rating -->
          <tr class="bg-gray-50/20 border-b border-gray-100 last:border-0">
            <td class="px-6 py-4 font-bold text-gray-500 bg-gray-50/50 border-r border-gray-100">Ratings Rating</td>
            <% products.forEach(p => { %>
              <td class="px-6 py-4 text-center border-r border-gray-100 last:border-0">
                <span class="inline-flex items-center space-x-1 py-1 px-2 rounded-lg bg-amber-50 border border-amber-205 text-amber-700 text-xs font-black">
                  <i data-lucide="star" class="w-3.5 h-3.5 fill-current text-amber-500"></i>
                  <span><%= p.rating %>★</span>
                </span>
              </td>
            <% }) %>
          </tr>

          <!-- Variant sizes -->
          <tr class="border-b border-gray-100 last:border-0">
            <td class="px-6 py-4 font-bold text-gray-500 bg-gray-50/50 border-r border-gray-100">Active Sizes</td>
            <% products.forEach(p => { %>
              <td class="px-6 py-4 text-center text-xs text-gray-600 border-r border-gray-100 last:border-0 truncate font-semibold">
                <%= p.sizes && p.sizes.length > 0 ? p.sizes.join(' | ') : 'Standard size' %>
              </td>
            <% }) %>
          </tr>

          <!-- Color Finishes -->
          <tr class="bg-gray-50/20 border-b border-gray-100 last:border-0">
            <td class="px-6 py-4 font-bold text-gray-500 bg-gray-50/50 border-r border-gray-100">Finish Color Options</td>
            <% products.forEach(p => { %>
              <td class="px-6 py-4 text-center text-xs text-gray-600 border-r border-gray-100 last:border-0 truncate">
                <%= p.colors && p.colors.length > 0 ? p.colors.join(' , ') : 'Generic' %>
              </td>
            <% }) %>
          </tr>

          <!-- Specifications loop helper -->
          <% 
            const allSpecsNames = Array.from(new Set(products.flatMap(p => (p.specifications || []).map(s => s.name))));
          %>
          <% allSpecsNames.forEach(specName => { %>
            <tr class="border-b border-gray-100 last:border-0">
              <td class="px-6 py-4 font-bold text-gray-500 bg-gray-50/50 border-r border-gray-100"><%= specName %></td>
              <% products.forEach(p => { %>
                <% 
                  const foundSpec = (p.specifications || []).find(s => s.name === specName);
                %>
                <td class="px-6 py-4 text-center text-xs text-gray-805 font-mono border-r border-gray-100 last:border-0">
                  <%= foundSpec ? foundSpec.value : '-- Not declared --' %>
                </td>
              <% }) %>
            </tr>
          <% }) %>

          <!-- Buy trigger actions -->
          <tr class="bg-gray-50/20 border-b border-gray-100 last:border-0">
            <td class="px-6 py-6 font-bold text-gray-500 bg-gray-50/50 border-r border-gray-100">Secure Purchase</td>
            <% products.forEach(p => { %>
              <td class="px-6 py-6 text-center border-r border-gray-100 last:border-0">
                <button onclick="compareQuickAddCart('<%= p.id || p._id %>')" <%= p.stock === 0 ? 'disabled' : '' %> class="w-full py-2 bg-amazon-gold text-slate-900 hover:bg-amber-600 font-extrabold rounded-lg transition text-xs shadow-sm disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed cursor-pointer border border-transparent">
                  Add to Cart
                </button>
              </td>
            <% }) %>
          </tr>
        </tbody>
      </table>
    </div>
  <% } %>

</main>

<script>
  // Splice comparison queues
  function popFromComparisonList(productId) {
    let list = JSON.parse(localStorage.getItem('shopzy_compare') || '[]');
    list = list.filter(id => id !== productId);
    localStorage.setItem('shopzy_compare', JSON.stringify(list));
    // Reload page with new list
    window.location.href = `/compare?productIds=${list.join(',')}`;
  }

  // Add to basket
  async function compareQuickAddCart(productId) {
    <% if (!user) { %>
      window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname + window.location.search)}`;
      return;
    <% } %>
    try {
      const payload = new URLSearchParams();
      payload.append('productId', productId);
      payload.append('quantity', '1');

      const response = await fetch('/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: payload
      });

      if (response.redirected) {
        const badge = document.getElementById('cartBadgeCount');
        if (badge) {
          let count = parseInt(badge.innerText.trim()) || 0;
          badge.innerText = count + 1;
        }
        triggerNotification('success', 'Product dispatched to Cart successfully.');
      }
    } catch {
      triggerNotification('error', 'Basket update error.');
    }
  }
</script>

<%- include('partials/footer') %>
