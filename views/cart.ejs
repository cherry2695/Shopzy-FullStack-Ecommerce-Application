<%- include('partials/header') %>

<!-- Dynamic notification alerts -->
<% if (typeof successMsg !== 'undefined' && successMsg) { %>
  <script>window.addEventListener('load', () => triggerNotification('success', '<%= successMsg %>'));</script>
<% } %>

<% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
  <script>window.addEventListener('load', () => triggerNotification('error', '<%= errorMsg %>'));</script>
<% } %>

<main class="max-w-7xl mx-auto px-4 py-8 flex-grow select-none">
  <div class="border-b border-gray-200 pb-4 mb-8">
    <h1 class="text-3xl font-bold font-display text-gray-950 tracking-tight flex items-center">
      <i data-lucide="shopping-basket" class="w-7 h-7 mr-2 text-amazon-gold"></i> Your Shopping Basket
    </h1>
    <p class="text-xs text-gray-500">Manage card quantities, apply discount coupons, and verify checkout estimates.</p>
  </div>

  <% if (!cart || cart.items.length === 0) { %>
    <!-- Empty Cart state -->
    <div class="bg-white border border-gray-200 rounded-2xl p-16 shadow-sm text-center">
      <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-orange-100 text-amazon-orange mb-4">
        <i data-lucide="shopping-cart" class="w-6 h-6"></i>
      </div>
      <h3 class="text-lg font-bold text-gray-900 mb-1">Your Shopzy Cart is Empty</h3>
      <p class="text-xs text-gray-500 max-w-sm mx-auto mb-6">Looks like you haven't booked any items yet. Browse catalogs to fill your basket.</p>
      <a href="/products" class="bg-amazon-gold text-amazon-navy text-xs font-black py-2.5 px-6 rounded-lg hover:bg-amazon-orange transition shadow">
        Continue Shopping
      </a>
    </div>
  <% } else { %>
    <!-- Main content split -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Primary items table (lg:col-span-8) -->
      <div class="lg:col-span-8 space-y-6">
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
          <div class="p-6 border-b border-gray-100 bg-gray-50/50 flex justify-between items-center">
            <h3 class="font-bold text-gray-900 text-sm">Shopping Cart Listings (<%= cart.items.length %> unique items)</h3>
            <span class="text-xs text-gray-500">Price currency: <strong>USD ($)</strong></span>
          </div>

          <div class="divide-y divide-gray-105">
            <% cart.items.forEach(item => { %>
              <div class="p-6 flex flex-col sm:flex-row items-start gap-4 sm:gap-6 group">
                <!-- Thumbnail -->
                <a href="/products/<%= item.productId %>" class="w-20 h-20 rounded-xl bg-gray-50 overflow-hidden flex-shrink-0 flex items-center justify-center border border-gray-150">
                  <img src="<%= item.image %>" alt="<%= item.title %>" class="h-full object-cover group-hover:scale-105 transition" referrerPolicy="no-referrer" />
                </a>

                <!-- Details -->
                <div class="flex-grow min-w-0 space-y-1">
                  <a href="/products/<%= item.productId %>" class="font-bold text-gray-950 hover:text-amazon-orange transition text-sm leading-tight block truncate"><%= item.title %></a>
                  
                  <!-- Variant info displays -->
                  <div class="flex flex-wrap gap-2 text-[10px] text-gray-500 font-semibold pt-1">
                    <% if (item.color) { %>
                      <span class="bg-gray-100 border border-gray-200 py-0.5 px-2 rounded"><%= item.color %> Finish</span>
                    <% } %>
                    <% if (item.size) { %>
                      <span class="bg-gray-100 border border-gray-200 py-0.5 px-2 rounded">Size: <%= item.size %></span>
                    <% } %>
                  </div>

                  <!-- Item Actions Row -->
                  <div class="flex items-center space-x-4 pt-3 text-xs font-semibold">
                    <!-- Quantity Update selector -->
                    <form action="/cart/update/<%= item.id || item._id %>" method="POST" class="flex items-center space-x-1.5">
                      <label class="text-gray-400 text-[10px]">QTY:</label>
                      <select name="quantity" onchange="this.form.submit()" class="bg-gray-50 text-gray-800 font-bold border border-gray-250 py-1 px-2.0 rounded text-xs focus:ring-1 focus:ring-amazon-gold cursor-pointer">
                        <% for(let i=1; i<=10; i++) { %>
                          <option value="<%= i %>" <%= item.quantity === i ? 'selected' : '' %>><%= i %></option>
                        <% } %>
                      </select>
                    </form>

                    <span class="text-gray-250">|</span>

                    <!-- Move to Save For Later -->
                    <a href="/cart/save-for-later/<%= item.id || item._id %>" class="text-amazon-gold hover:underline flex items-center"><i data-lucide="archive" class="w-3.5 h-3.5 mr-1"></i> Save for Later</a>
                    
                    <span class="text-gray-250">|</span>

                    <!-- Delete node -->
                    <a href="/cart/remove/<%= item.id || item._id %>" class="text-red-500 hover:underline flex items-center"><i data-lucide="trash-2" class="w-3.5 h-3.5 mr-1"></i> Delete</a>
                  </div>
                </div>

                <!-- Price computations -->
                <div class="text-right flex-shrink-0">
                  <p class="font-mono font-black text-gray-950 text-base leading-none">Rs. <%= item.price * item.quantity %></p>
                  <p class="text-[10px] text-gray-400 leading-none mt-1">(Rs. <%= item.price %> each)</p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Right Summary bento calculator (lg:col-span-4) -->
      <aside class="lg:col-span-4 space-y-6">
        
        <!-- BILLING CALCULATOR -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm space-y-4">
          <h3 class="font-bold text-gray-900 border-b border-gray-100 pb-2 text-sm font-display tracking-tight flex items-center">
            <i data-lucide="calculator" class="w-4 h-4 mr-1.5 text-gray-400"></i> Order Checkout Billing
          </h3>

          <div class="space-y-2.5 text-xs text-gray-650 font-semibold">
            <div class="flex justify-between">
              <span>Items Subtotal</span>
              <span class="font-mono text-gray-900">Rs. <%= pricing.subtotal %></span>
            </div>

            <% if (pricing.discount > 0) { %>
              <div class="flex justify-between text-green-700">
                <span>Coupon Sales Offer</span>
                <span class="font-mono">- Rs. <%= pricing.discount %></span>
              </div>
            <% } %>

            <div class="flex justify-between">
              <span>Delivery Shipping Charge</span>
              <span class="font-mono text-gray-900">
                <%= pricing.shipping === 0 ? 'FREE' : `Rs. ${pricing.shipping}` %>
              </span>
            </div>

            <div class="flex justify-between">
              <span>Estimated Tax (18% GST)</span>
              <span class="font-mono text-gray-900">Rs. <%= pricing.tax %></span>
            </div>

            <!-- Free delivery indicator slider -->
            <% if (pricing.subtotal < 1500) { %>
              <div class="bg-orange-50 border border-orange-100 p-3 rounded-lg text-[10px]">
                <p class="text-orange-850 leading-tight flex items-center">
                  <i data-lucide="info" class="w-3.5 h-3.5 mr-1 flex-shrink-0"></i> Add <strong>Rs. <%= 1500 - pricing.subtotal %></strong> more to unlock <strong>FREE SHIPPING!</strong>
                </p>
                <div class="w-full bg-gray-200 h-1 rounded-full mt-2 overflow-hidden">
                  <div class="bg-amazon-orange h-full rounded-full" style="width: <%= (pricing.subtotal / 1500) * 100 %>%"></div>
                </div>
              </div>
            <% } else { %>
              <div class="bg-green-50 border border-green-100 p-2 rounded-lg text-[10px] text-green-800 flex items-center font-bold">
                <i data-lucide="truck" class="w-4 h-4 mr-1 text-green-600"></i> Free standard shipping secured!
              </div>
            <% } %>

            <hr class="border-gray-200">

            <div class="flex justify-between text-base font-black text-gray-950 pb-1">
              <span class="font-display">Grand Total (Est.)</span>
              <span class="font-mono">Rs. <%= pricing.total %></span>
            </div>
          </div>

          <!-- Checkout call action -->
          <a href="/checkout" class="block w-full py-3 bg-amazon-orange hover:bg-amazon-gold text-amazon-navy text-center font-bold rounded-lg transition text-sm shadow cursor-pointer">
            Proceed Secure Checkout
          </a>
        </div>

        <!-- promo COUPON MODULE -->
        <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm space-y-4">
          <h3 class="font-bold text-gray-905 text-xs font-display uppercase tracking-wider flex items-center">
            <i data-lucide="ticket-percent" class="w-4.5 h-4.5 mr-1.5 text-amazon-gold"></i> Apply Promo Code
          </h3>
          
          <% if (couponCode) { %>
            <div class="bg-emerald-50 border border-emerald-200 p-3 rounded-lg flex items-center justify-between">
              <div class="text-xs">
                <p class="font-black font-mono text-emerald-800"><%= couponCode %></p>
                <p class="text-[10px] text-emerald-600">Active discount applied successfully.</p>
              </div>
              <a href="/cart/remove-coupon" class="text-xs text-red-500 hover:underline font-bold">Remove</a>
            </div>
          <% } else { %>
            <form action="/cart/apply-coupon" method="POST" class="flex gap-2">
              <input 
                type="text" 
                name="code" 
                required 
                placeholder="e.g. SHOPZY10" 
                class="w-full text-xs px-3.5 py-2 bg-gray-50 border border-gray-250 rounded-lg font-mono font-bold uppercase focus:outline-none"
              />
              <button type="submit" class="bg-amazon-gold text-amazon-navy font-bold text-xs py-2 px-4 rounded-lg hover:bg-amazon-orange transition select-none cursor-pointer border border-transparent">
                Apply
              </button>
            </form>
            <p class="text-[10px] text-gray-400">Sandbox Code list: <strong>SHOPZY10</strong> (10% off), <strong>FESTIVE500</strong> (Flat Rs. 500 off on bills over Rs. 4999)</p>
          <% } %>
        </div>

      </aside>
    </div>
  <% } %>

  <!-- SAVE FOR LATER MODULE SHELF -->
  <% if (typeof saveForLater !== 'undefined' && saveForLater && saveForLater.length > 0) { %>
    <section class="mt-16 border-t border-gray-200 pt-10 space-y-6">
      <h3 class="text-xl font-bold font-display text-gray-900 tracking-tight flex items-center">
        <i data-lucide="archive" class="w-5.5 h-5.5 mr-1.5 text-amazon-gold"></i> Saved for Later Shelf (<%= saveForLater.length %>)
      </h3>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
        <% saveForLater.forEach((item, idx) => { %>
          <div class="bg-white border border-gray-220 rounded-xl p-4 shadow-sm flex flex-col justify-between group h-max">
            <div>
              <div class="h-32 rounded bg-gray-50 flex items-center justify-center overflow-hidden mb-3 relative">
                <img src="<%= item.image %>" alt="<%= item.title %>" class="h-full object-cover group-hover:scale-105 transition" referrerPolicy="no-referrer" />
              </div>
              <h4 class="font-bold text-xs text-gray-900 group-hover:text-amazon-orange line-clamp-2 leading-snug"><%= item.title %></h4>
              <p class="font-mono text-xs font-black text-gray-900 mt-1.5">Rs. <%= item.price %></p>
            </div>
            
            <a href="/cart/move-to-cart/<%= idx %>" class="mt-4 w-full py-1.5 bg-amazon-gold hover:bg-amber-600 text-amazon-navy border border-transparent rounded text-center text-[11px] font-black uppercase transition block shadow-sm">
              Restore into Cart
            </a>
          </div>
        <% }) %>
      </div>
    </section>
  <% } %>

</main>

<%- include('partials/footer') %>
