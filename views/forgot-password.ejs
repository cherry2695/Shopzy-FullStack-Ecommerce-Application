<%- include('partials/header') %>

<main class="max-w-md mx-auto my-16 px-6 flex-grow flex flex-col justify-center w-full">
  <div class="bg-white rounded-2xl shadow-xl border border-gray-150 p-8 select-none">
    <div class="text-center mb-6">
      <h2 class="text-2xl font-bold font-display text-gray-950 tracking-tight">Password Assistance</h2>
      <p class="text-xs text-gray-500 mt-1">Submit your account email to dispatch a visual reset PIN</p>
    </div>

    <!-- Alerts -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 text-xs font-semibold rounded-lg p-3.5 mb-6 flex items-center">
        <i data-lucide="info" class="w-4 h-4 mr-2 text-red-500"></i> <%= error %>
      </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-teal-50 border border-teal-200 text-teal-850 text-xs font-semibold rounded-lg p-4 mb-6 relative">
        <p class="font-extrabold flex items-center text-teal-700 mb-1"><i data-lucide="check-circle" class="w-4 h-4 mr-1.5 text-teal-600 animate-bounce"></i> Process Initiated!</p>
        <p class="leading-relaxed"><%= success %></p>
      </div>

      <!-- Password mutations reset form directly -->
      <form action="/reset-password" method="POST" class="space-y-4">
        <input type="hidden" name="email" value="<%= email %>" />

        <div>
          <label class="block text-xs font-bold text-gray-605 uppercase tracking-wider mb-1">Enter PIN Code</label>
          <input 
            type="text" 
            name="pin" 
            required 
            placeholder="Specify 6 Digit PIN" 
            class="w-full text-sm px-4 py-2.5 border border-gray-250 bg-gray-50 rounded-lg text-center font-mono font-black tracking-widest focus:outline-none focus:ring-1 focus:ring-amazon-gold"
          />
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-605 uppercase tracking-wider mb-1">Establish New Password</label>
          <input 
            type="password" 
            name="password" 
            required 
            placeholder="Minimum 6 characters" 
            class="w-full text-sm px-4 py-2.5 border border-gray-250 rounded-lg focus:outline-none focus:ring-1 focus:ring-amazon-gold"
          />
        </div>

        <button type="submit" class="w-full py-3 rounded-lg bg-amazon-orange hover:bg-amazon-gold text-amazon-navy font-bold text-sm tracking-tight transition shadow cursor-pointer">
          Confirm Credentials Reset
        </button>
      </form>

    <% } else { %>
      <!-- Step 1: Submit email -->
      <form action="/forgot-password" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs font-bold text-gray-605 uppercase tracking-wider mb-1">Email Address</label>
          <input 
            type="email" 
            name="email" 
            required 
            placeholder="e.g. name@domain.com" 
            class="w-full text-sm px-4 py-2.5 border border-gray-250 rounded-lg focus:outline-none focus:ring-1 focus:ring-amazon-gold"
          />
        </div>

        <button type="submit" class="w-full py-3 rounded-lg bg-amazon-orange hover:bg-amazon-gold text-amazon-navy font-bold text-sm tracking-tight transition shadow cursor-pointer">
          Request Assistance PIN
        </button>
      </form>
    <% } %>

    <div class="border-t border-gray-150 mt-6 pt-5 text-center text-xs text-gray-600">
      Back to <a href="/login" class="font-bold text-amazon-gold hover:underline">Sign In Portal</a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
