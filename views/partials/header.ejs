    <!-- Responsive scripts self-contained for mobile category toggle & searchable Category Menu -->
    <script>
      function toggleMobileCategory(id) {
        const el = document.getElementById(id);
        const icon = document.getElementById(id + '-icon');
        if (el) {
          el.classList.toggle('hidden');
          el.classList.toggle('flex');
        }
        if (icon) {
          icon.classList.toggle('rotate-180');
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        const srcInput = document.getElementById('catMenuSearchInput');
        const itemsList = document.getElementById('catMenuList');
        const noResults = document.getElementById('catMenuNoResults');

        if (srcInput && itemsList) {
          srcInput.addEventListener('input', () => {
            const queryTerm = srcInput.value.toLowerCase().trim();
            const items = itemsList.getElementsByClassName('cat-menu-item');
            let matchedAny = false;

            for (let item of items) {
              const names = item.getAttribute('data-name') || '';
              if (names.includes(queryTerm)) {
                item.classList.remove('hidden');
                matchedAny = true;
              } else {
                item.classList.add('hidden');
              }
            }

            if (noResults) {
              if (matchedAny) {
                noResults.classList.add('hidden');
              } else {
                noResults.classList.remove('hidden');
              }
            }
          });
        }
      });
    </script>
