<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Shopzy - Premium Marketplace' %></title>
  
  <!-- Modern Font Pack -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Client-side Tailwind Engine -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Lucide Icons CDN -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.469.0/dist/umd/lucide.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
            display: ['Space Grotesk', 'sans-serif'],
            mono: ['Fira Code', 'monospace']
          },
          colors: {
            amazon: {
              navy: '#0f172a',      // slate-900
              squid: '#1e293b',     // slate-800
              accent: '#334155',    // slate-700
              orange: '#FF9900',    // yellow-500
              gold: '#f59e0b',      // amber-500
              slate: {
                50: '#f8fafc',
                100: '#f1f5f9',
                200: '#e2e8f0',
                300: '#cbd5e1',
                400: '#94a3b8',
                500: '#64748b',
                600: '#475569',
                700: '#334155',
                800: '#1e293b',
                900: '#0f172a'
              }
            }
          }
        }
      }
    }
  </script>
  <style>
    /* Prevent FOUC and add nice smooth transitions */
    body {
      font-family: 'Inter', sans-serif;
      scroll-behavior: smooth;
    }
    .font-display {
      font-family: 'Space Grotesk', sans-serif;
    }
    .font-mono {
      font-family: 'Fira Code', monospace;
    }
    /* Simple custom zoom classes */
    .zoom-container {
      overflow: hidden;
    }
    .zoom-image {
      transition: transform .3s ease;
    }
    .zoom-container:hover .zoom-image {
      transform: scale(1.15);
    }
    /* Hide scrollbars cross-browser */
    .scrollbar-none::-webkit-scrollbar,
    .no-scrollbar::-webkit-scrollbar {
      display: none !important;
    }
    .scrollbar-none,
    .no-scrollbar {
      -ms-overflow-style: none !important;  /* IE and Edge */
      scrollbar-width: none !important;  /* Firefox */
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col font-sans">

  <!-- Header Section -->
  <header class="sticky top-0 z-50 shadow-md">
    <%
      const isActive = (catName) => {
        const currentQuery = (typeof query !== 'undefined' && query.category) ? query.category.toLowerCase() : '';
        const currentPath = (typeof path !== 'undefined') ? path.toLowerCase() : '';
        const matchName = catName.toLowerCase();
        
        if (currentQuery === matchName || currentQuery === matchName.replace(/\s+/g, '+') || currentQuery === encodeURIComponent(catName).toLowerCase() || currentQuery === matchName.replace(/\s+/g, '-')) {
          return true;
        }
        
        if (currentPath === `/products/${matchName}` || currentPath === `/products/${matchName.replace(/\s+/g, '-')}` || currentPath.endsWith(`/${matchName.replace(/\s+/g, '-')}`)) {
          return true;
        }
        
        return false;
      };

      const isElectronicsActive = isActive('Smartphones') || isActive('Laptops') || isActive('Smart Watches') || isActive('Bluetooth Earbuds') || isActive('Speakers') || isActive('Headphones') || isActive('Cameras') || isActive('gaming-accessories') || isActive('monitors') || isActive('tablets') || isActive('Gaming Accessories') || isActive('Monitors') || isActive('Tablets');
      const isFashionActive = isActive('Mens Clothing') || isActive("Men's Clothing") || isActive('Womens Clothing') || isActive("Women's Clothing") || isActive('Shoes') || isActive('Sports Wear');
      const isHomeActive = isActive('Furniture') || isActive('Home Decor') || isActive('Kitchen Appliances');
      const isSportsActive = isActive('Fitness Equipment') || isActive('Sports Equipment') || isActive('Fitness Accessories');
      const isMoreActive = isActive('Bags and Travel Accessories') || isActive('Gaming Accessories') || isActive('Monitors') || isActive('Tablets') || isActive('Bags+and+Travel+Accessories');
    %>

    <!-- LEVEL 1: TOP BAR -->
    <div class="bg-amazon-navy text-xs text-gray-300 h-10 border-b border-gray-800 flex items-center w-full select-none px-6">
      <div class="w-full max-w-[1440px] mx-auto flex justify-between items-center">
        <div class="flex items-center gap-6">
          <span class="flex items-center text-amazon-orange font-semibold animate-pulse">
            <i data-lucide="sparkles" class="w-3.5 h-3.5 mr-1.5 shrink-0"></i> Special Launch Deals! Use Code: <strong class="ml-1 text-white">SHOPZY10</strong>
          </span>
          <span class="text-slate-700 hidden md:inline">|</span>
          <span class="hidden md:flex items-center text-slate-300 whitespace-nowrap animate-fade-in">
            <i data-lucide="map-pin" class="w-3.5 h-3.5 mr-1.5 text-slate-400 shrink-0"></i> Deliver to <span class="text-white font-semibold ml-1">Hyderabad 500043</span>
          </span>
        </div>
        <div class="flex items-center gap-4 animate-fade-in">
          <a href="/contact" class="hover:text-white transition">Customer Service</a>
          <% if (user && user.role === 'admin') { %>
            <span class="text-slate-700">|</span>
            <a href="/admin" class="bg-red-650/90 text-white font-bold py-0.5 px-2.5 rounded-full flex items-center hover:bg-red-700 transition">
              <i data-lucide="shield" class="w-3 h-3 mr-1"></i> Admin Panel
            </a>
          <% } %>
        </div>
      </div>
    </div>

    <!-- LEVEL 2: MAIN HEADER -->
    <div class="bg-[#0f172a] text-white py-3 md:py-0 md:h-[80px] border-b border-slate-800 flex items-center w-full px-6">
      <div class="w-full max-w-[1440px] mx-auto flex flex-col md:flex-row md:items-center justify-between gap-4 md:gap-6">
        
        <!-- Column 1: SHOPZY Logo (Width 220px, Gap 16px, vertically centered) -->
        <div class="w-full md:w-[220px] flex items-center justify-between md:justify-start gap-4 shrink-0">
          <div class="flex items-center gap-4">
            <button id="mobileMenuBtn" class="md:hidden p-2 text-white hover:text-amazon-orange focus:outline-none transition-colors">
              <i data-lucide="menu" class="w-6 h-6"></i>
            </button>
            <a href="/" class="flex items-center gap-4 text-2xl font-bold font-display tracking-tight text-white select-none group">
              <div class="w-10 h-10 bg-gradient-to-tr from-blue-600 to-indigo-500 rounded-xl flex items-center justify-center font-bold text-xl tracking-tighter text-white shadow-lg transition-all duration-300 group-hover:scale-110 group-hover:shadow-indigo-500/30">
                <i data-lucide="shopping-bag" class="w-5 h-5 text-white"></i>
              </div>
              <span class="text-2xl font-black tracking-tight uppercase bg-gradient-to-r from-white via-slate-100 to-slate-200 bg-clip-text text-transparent">Shopzy</span>
            </a>
          </div>

          <!-- Mobile Cart Shortcut -->
          <div class="flex items-center md:hidden shrink-0">
            <a href="/cart" class="relative flex items-center p-2 hover:bg-slate-800/40 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="8" cy="21" r="1"></circle>
                <circle cx="19" cy="21" r="1"></circle>
                <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
              </svg>
              <span id="cartBadgeCountMobile" class="absolute top-0 right-0 bg-amber-500 text-slate-900 text-[10px] font-black rounded-full w-4.5 h-4.5 flex items-center justify-center ring-2 ring-slate-900">
                <%= cartCount %>
              </span>
            </a>
          </div>
        </div>

        <!-- Column 2: Search Bar (Slightly Reduced Width to 620px for Visual Excellence) -->
        <div class="w-full md:flex-1 max-w-[620px] relative flex items-center bg-white rounded-[10px] h-[50px] border border-slate-700/50 shadow-inner group transition-all duration-300 focus-within:ring-2 focus-within:ring-amazon-orange shrink">
          <form action="/products" method="GET" class="flex w-full h-[50px]" id="globalSearchForm">
            <!-- Departments Dropdown -->
            <button type="button" class="px-4 h-[50px] bg-slate-100 text-slate-700 text-xs font-semibold border-r border-slate-200 hover:bg-slate-200 transition-colors hidden lg:block shrink-0 rounded-l-[10px] select-none cursor-pointer">
              All Departments
            </button>
            <!-- Search Input -->
            <div class="flex-1 relative flex items-center h-[50px]">
              <input 
                type="text" 
                name="search" 
                id="globalSearchInput" 
                placeholder="Search smartphones, laptops, clothing..." 
                autocomplete="off"
                value="<%= typeof query !== 'undefined' && query.search ? query.search : '' %>"
                class="w-full px-4 text-slate-800 text-sm focus:outline-none bg-white border-0 h-[50px] rounded-l-[10px] lg:rounded-l-none"
              />
            </div>
            <!-- Search Button (Width: 70px) -->
            <button type="submit" class="w-[70px] h-[50px] bg-amazon-gold hover:bg-amazon-gold/90 text-slate-900 flex items-center justify-center transition-colors shrink-0 rounded-r-[10px]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-900" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </button>
          </form>

          <!-- Floating Autocomplete Suggestions Panel -->
          <div id="searchResultsPopup" class="absolute left-0 right-0 top-full mt-1.5 bg-white border border-gray-200 rounded-lg shadow-2xl hidden z-50 overflow-hidden text-gray-900 text-sm">
            <!-- Dynamic items go here -->
          </div>
        </div>

        <!-- Right Side Actions: Premium group to prevent cramped styling and spacing stretching -->
        <div class="hidden md:flex items-center gap-[32px] lg:gap-[40px] shrink-0 select-none">
          <!-- Account Section -->
          <% if (user) { %>
            <div class="relative group py-2">
              <button class="flex items-center space-x-1 hover:text-amazon-orange transition focus:outline-none cursor-pointer">
                <div class="text-left">
                  <p class="text-[10px] text-gray-400 font-medium tracking-tight leading-3">Hello, <%= user.name.split(' ')[0] %></p>
                  <p class="text-xs lg:text-sm font-bold flex items-center leading-4">
                    Accounts & Lists <i data-lucide="chevron-down" class="w-3.5 h-3.5 ml-0.5 text-slate-400"></i>
                  </p>
                </div>
              </button>
              <div class="absolute right-0 w-48 mt-2 py-2 bg-white text-gray-800 rounded-lg shadow-xl border border-gray-100 hidden group-hover:block z-50">
                <a href="/profile" class="block px-4 py-2 hover:bg-gray-100 text-sm flex items-center"><i data-lucide="user" class="w-4 h-4 mr-2 text-gray-400"></i> My Profile</a>
                <a href="/orders" class="block px-4 py-2 hover:bg-gray-100 text-sm flex items-center"><i data-lucide="package" class="w-4 h-4 mr-2 text-gray-400"></i> Orders History</a>
                <a href="/wishlist" class="block px-4 py-2 hover:bg-gray-100 text-sm flex items-center"><i data-lucide="heart" class="w-4 h-4 mr-2 text-gray-400"></i> Wishlist</a>
                <hr class="border-gray-100 my-2">
                <a href="/logout" class="block px-4 py-2 hover:bg-red-50 text-red-600 font-medium text-sm flex items-center"><i data-lucide="log-out" class="w-4 h-4 mr-2 text-red-500"></i> Log Out</a>
              </div>
            </div>
          <% } else { %>
            <a href="/login" class="flex flex-col items-start leading-none hover:text-amazon-orange transition select-none">
              <span class="text-[10px] text-slate-400 uppercase tracking-widest leading-3">Hello, Sign In</span>
              <span class="text-sm font-bold leading-4">Accounts & Lists</span>
            </a>
          <% } %>

          <!-- Wishlist Direct Entry -->
          <a href="/wishlist" class="flex flex-col items-start leading-none hover:text-amazon-orange transition relative select-none">
            <span class="text-[10px] text-slate-400 uppercase tracking-widest leading-3">Returns</span>
            <span class="text-sm font-bold leading-4">& Wishlist</span>
          </a>

          <!-- Cart Section -->
          <a href="/cart" class="relative flex items-center gap-2 hover:text-amazon-orange transition select-none h-12 px-3 rounded-lg hover:bg-slate-800/40">
            <div class="relative flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="8" cy="21" r="1"></circle>
                <circle cx="19" cy="21" r="1"></circle>
                <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
              </svg>
              <span id="cartBadgeCount" class="absolute -top-1 -right-2 bg-amber-500 text-slate-900 text-[10px] font-black rounded-full w-5 h-5 flex items-center justify-center ring-2 ring-slate-900">
                <%= cartCount %>
              </span>
            </div>
            <span class="text-sm font-bold text-white hidden xl:inline ml-1">Cart</span>
          </a>
        </div>

      </div>
    </div>

    <!-- LEVEL 3: CATEGORY NAVIGATION -->
    <div class="bg-[#1f2937] text-white h-[64px] relative border-b border-slate-800 flex items-center w-full px-6">
      <div class="w-full max-w-[1440px] mx-auto h-full flex items-center justify-between gap-6">
        
        <!-- Left Section: Navigation links with gap 32px (laptop 24px) -->
        <div class="flex items-center gap-[16px] md:gap-[20px] lg:gap-[24px] xl:gap-[32px] h-full overflow-x-auto lg:overflow-visible no-scrollbar scrollbar-none whitespace-nowrap w-full lg:w-auto">
          
          <!-- Menu Item 1: All Categories (searchable menu) -->
          <div class="relative group h-full flex items-center">
            <button class="px-4 py-1.5 text-[14px] font-medium text-white flex items-center gap-1.5 hover:bg-[#2A3746] rounded-xl transition-all duration-300 cursor-pointer whitespace-nowrap bg-slate-700/50 border border-slate-700/70 shadow-sm focus:outline-none">
              <i data-lucide="menu" class="w-4 h-4 text-slate-200 font-bold"></i> All Categories
            </button>
            
            <div class="absolute left-0 top-full mt-0 w-80 bg-white text-slate-800 shadow-2xl rounded-b-xl border border-slate-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible translate-y-2 group-hover:translate-y-0 transition-all duration-300 z-50 p-4 flex flex-col gap-2">
              <div class="font-bold text-xs text-slate-400 uppercase tracking-wider pb-1 flex justify-between items-center">
                <span>Direct Search Portal</span>
                <i data-lucide="search" class="w-3.5 h-3.5"></i>
              </div>
              
              <!-- Search categories filter input -->
              <div class="relative mb-2">
                <input 
                  type="text" 
                  id="catMenuSearchInput" 
                  placeholder="Type to filter categories..." 
                  class="w-full px-3 py-2 pl-8 text-xs text-slate-800 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-amazon-orange focus:bg-white transition-colors"
                />
                <i data-lucide="sliders-horizontal" class="absolute left-2.5 top-2.5 w-3.5 h-3.5 text-slate-400"></i>
              </div>

              <!-- List of ALL categories -->
              <div id="catMenuList" class="max-h-60 overflow-y-auto pr-1 flex flex-col gap-0.5 custom-scrollbar text-sm">
                <a href="/products" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition" data-name="all products browse core catalog">
                  <span>Browse All Products</span>
                  <i data-lucide="arrow-right" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Smartphones" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Smartphones') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="smartphones mobile phones cellular apple android samsung">
                  <span>Smartphones</span>
                  <i data-lucide="smartphone" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Laptops" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Laptops') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="laptops computers notebooks workspaces macbooks dell asus">
                  <span>Laptops</span>
                  <i data-lucide="laptop" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Smart+Watches" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Smart Watches') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="watches apple watch smart wear smartwatches wearables fitness">
                  <span>Smart Watches</span>
                  <i data-lucide="watch" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Bluetooth+Earbuds" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Bluetooth Earbuds') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="bluetooth earbuds ear buds headphones audio airpods jabra bose silence">
                  <span>Bluetooth Earbuds</span>
                  <i data-lucide="pocket" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Headphones" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Headphones') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="headphones sound headsets ear headset gaming air">
                  <span>Headphones</span>
                  <i data-lucide="headphones" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Speakers" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Speakers') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="speakers sound docks audio boom bar harman sony bluetooth flex text search speaker">
                  <span>Speakers</span>
                  <i data-lucide="speaker" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Cameras" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Cameras') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="cameras dslr photography video lenses dji canon nikon">
                  <span>Cameras</span>
                  <i data-lucide="camera" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Mens+Clothing" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Mens Clothing') || isActive("Men's Clothing") ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="mens clothing apparel garments shirts pants outerwear t-shirts zara raymond">
                  <span>Men's Apparel</span>
                  <i data-lucide="shirt" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Womens+Clothing" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Womens Clothing') || isActive("Women's Clothing") ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="womens clothing fashion dresses apparel ladies tops designer zara">
                  <span>Women's Fashion</span>
                  <i data-lucide="sparkles" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Shoes" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Shoes') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="shoes sneakers loafers boots athletic sports boots fit nike puma adidas">
                  <span>Shoes</span>
                  <i data-lucide="footprints" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Sports+Wear" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Sports Wear') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="sports wear athletic clothing gym jerseys activewear fitness fit workout nike">
                  <span>Sports Wear</span>
                  <i data-lucide="activity" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Furniture" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Furniture') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="furniture sofas chairs tables desks home office bed living room">
                  <span>Furniture</span>
                  <i data-lucide="armchair" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Home+Decor" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Home Decor') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="home decor decorations cushions mirrors paintings clocks living styling design luxury">
                  <span>Home Decor</span>
                  <i data-lucide="home" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
                <a href="/products?category=Kitchen+Appliances" class="cat-menu-item flex items-center justify-between p-2 hover:bg-slate-50 rounded-lg text-slate-700 hover:text-amazon-orange font-medium transition <%= isActive('Kitchen Appliances') ? 'bg-[#FF9900] text-white hover:text-white rounded-[8px]' : '' %>" data-name="kitchen appliances microwave blenders cookers pan kitchen tools ovens items prestige">
                  <span>Kitchen Appliances</span>
                  <i data-lucide="utensils" class="w-3.5 h-3.5 text-slate-400"></i>
                </a>
