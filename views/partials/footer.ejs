  <!-- Lucide Icon Trigger & Autocomplete JS Scripts -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Fire up Lucide Icon renderer nicely
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      } else {
        console.warn('Lucide not loaded initially. Retrying replacement in 800ms...');
        setTimeout(() => {
          if (typeof lucide !== 'undefined') lucide.createIcons();
        }, 800);
      }

      // 2. Mobile Responsive Hamburguer Toggle Toggle
      const mobileBtn = document.getElementById('mobileMenuBtn');
      const mobileMenu = document.getElementById('mobileMenu');
      if (mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
          mobileMenu.classList.toggle('flex');
        });
      }

      // 3. Global Instant Autocomplete/Search Popup
      const searchInput = document.getElementById('globalSearchInput');
      const popup = document.getElementById('searchResultsPopup');

      if (searchInput && popup) {
        let fetchTimeout;

        searchInput.addEventListener('input', () => {
          clearTimeout(fetchTimeout);
          const term = searchInput.value.trim();

          if (term.length < 2) {
            popup.classList.add('hidden');
            return;
          }

          // Debounce fetch requests by 150ms to keep it extremely fast and lightweight
          fetchTimeout = setTimeout(async () => {
            try {
              const res = await fetch(`/api/suggestions?term=${encodeURIComponent(term)}`);
              const suggestions = await res.json();

              if (!suggestions || suggestions.length === 0) {
                popup.classList.add('hidden');
                return;
              }

              popup.innerHTML = '';
              suggestions.forEach(item => {
                const row = document.createElement('a');
                row.href = `/products/${item.id}`;
                row.className = "flex items-center space-x-3 p-3 hover:bg-gray-50 border-b border-gray-100 last:border-0 transition";
                row.innerHTML = `
                  <img src="${item.image}" alt="${item.title}" class="w-9 h-9 object-cover rounded shadow-inner" referrerPolicy="no-referrer" />
                  <div class="flex-1 min-w-0">
                    <p class="font-semibold text-gray-900 truncate">${item.title}</p>
                    <p class="text-xs text-green-600 font-mono font-bold">Rs. ${item.price}</p>
                  </div>
                `;
                popup.appendChild(row);
              });

              popup.classList.remove('hidden');
            } catch (err) {
              console.error('Autocomplete query failed:', err);
            }
          }, 150);
        });

        // Close search popup if clicked outside
        document.addEventListener('click', (e) => {
          if (!searchInput.contains(e.target) && !popup.contains(e.target)) {
            popup.classList.add('hidden');
          }
        });
      }
    });

    // Elegant helper to trigger alerts
    function triggerNotification(type, message) {
      const parent = document.createElement('div');
      parent.className = `fixed bottom-5 right-5 z-50 p-4 rounded-xl shadow-2xl flex items-center space-x-3 transform transition-all duration-300 ring-1 ${
        type === 'success' ? 'bg-emerald-50 ring-emerald-300 text-emerald-800' : 'bg-red-50 ring-red-300 text-red-800'
      }`;
      parent.innerHTML = `
        <span class="p-1 rounded-full ${type === 'success' ? 'bg-emerald-550 text-emerald-600' : 'bg-red-550 text-red-605'}">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="${
            type === 'success' ? 'M5 13l4 4L19 7' : 'M6 18L18 6M6 6l12 12'
          }"></path></svg>
        </span>
        <p class="text-sm font-bold">${message}</p>
      `;
      document.body.appendChild(parent);
      setTimeout(() => {
        parent.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => parent.remove(), 350);
      }, 3500);
    }
  </script>
