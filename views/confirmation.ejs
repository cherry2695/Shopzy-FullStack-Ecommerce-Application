<%- include('partials/header') %>

<main class="max-w-3xl mx-auto my-12 px-6 flex-grow flex flex-col justify-center select-none">
  <div class="bg-white rounded-2xl shadow-xl border border-gray-150 p-8 sm:p-10 relative overflow-hidden">
    <!-- Top banner celebration -->
    <div class="absolute top-0 inset-x-0 h-2 bg-gradient-to-r from-emerald-400 via-teal-500 to-green-600"></div>

    <div class="text-center mb-8">
      <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-emerald-50 text-emerald-600 mb-4 ring-4 ring-emerald-500/10">
        <i data-lucide="party-popper" class="w-7 h-7 text-emerald-600 animate-bounce"></i>
      </div>
      <h2 class="text-3xl font-bold font-display tracking-tight text-gray-950">Thank You For Your Order!</h2>
      <p class="text-xs text-gray-500 mt-1">Your order transaction has been approved and compiled.</p>
    </div>

    <!-- Details block -->
    <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200 grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-semibold text-gray-650 mb-8">
      <div class="space-y-1.5 border-b md:border-b-0 md:border-r border-gray-200 pb-3 md:pb-0 md:pr-4">
        <p class="text-gray-400 font-bold uppercase tracking-wider text-[10px]">TRANSACTION METRICS</p>
        <p class="text-gray-900 leading-normal">Receipt Ref: <strong class="font-mono text-gray-950"><%= order.orderId %></strong></p>
        <p class="text-gray-900">Captured Date: <strong class="font-mono text-gray-950"><%= new Date(order.createdAt).toLocaleDateString() %></strong></p>
        <p class="text-gray-901">Gateway Mode: <strong class="text-blue-600"><%= order.paymentMethod %></strong></p>
        <p class="text-gray-901">Transaction Status: <span class="bg-green-100 text-green-805 text-[9px] font-black tracking-wider py-0.5 px-2 rounded-full font-display">APPROVED</span></p>
      </div>

      <div class="space-y-1.5 md:pl-4">
        <p class="text-gray-400 font-bold uppercase tracking-wider text-[10px]">DELIVERY DESTINATION</p>
        <p class="font-bold text-gray-950"><%= order.shippingAddress.fullName %></p>
        <p class="text-gray-500"><%= order.shippingAddress.addressLine1 %></p>
        <% if (order.shippingAddress.addressLine2) { %>
          <p class="text-gray-500"><%= order.shippingAddress.addressLine2 %></p>
        <% } %>
        <p class="text-gray-500"><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.postalCode %></p>
        <p class="text-gray-900 mt-1">Recipient Phone: <strong class="font-mono text-gray-950"><%= order.shippingAddress.phone %></strong></p>
      </div>
    </div>

    <!-- Items details lists -->
    <div class="border border-gray-150 rounded-2xl overflow-hidden mb-8 text-xs font-semibold">
      <div class="p-4 bg-gray-51 border-b border-gray-150 flex justify-between items-center bg-gray-50/50">
        <h4 class="font-bold text-gray-900">Listings Ordered</h4>
        <span class="text-gray-400">Total items: <%= order.items.length %></span>
      </div>

      <div class="divide-y divide-gray-105">
        <% order.items.forEach(item => { %>
          <div class="p-4 flex justify-between items-center gap-4">
            <div class="flex items-center space-x-3">
              <img src="<%= item.image %>" class="w-10 h-10 object-cover border rounded" referrerPolicy="no-referrer" />
              <div>
                <p class="font-bold text-gray-950 leading-snug"><%= item.title %></p>
                <p class="text-[10px] text-gray-400">QTY: <%= item.quantity %> x Rs. <%= item.price %></p>
              </div>
            </div>
            <p class="font-mono font-bold text-gray-950">Rs. <%= item.price * item.quantity %></p>
          </div>
        <% }) %>
      </div>

      <div class="p-4 bg-gray-50/20 border-t border-gray-150 text-right space-y-1 text-gray-650">
        <p>GST Tax (18% included): <strong class="font-mono text-gray-900">Rs. <%= order.pricing.tax %></strong></p>
        <p>Shipping logistics: <strong class="font-mono text-gray-900"><%= order.pricing.shipping === 0 ? 'FREE' : `Rs. ${order.pricing.shipping}` %></strong></p>
        <p class="text-sm font-black text-gray-950 pt-1">Grand Final Amount: <strong class="font-mono text-gray-950 text-base">Rs. <%= order.pricing.total %></strong></p>
      </div>
    </div>

    <!-- Bottom Actions row -->
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 relative z-10 w-full md:w-auto">
      <a href="/orders/track/<%= order.orderId %>" class="w-full sm:w-auto px-6 py-2.5 rounded-lg bg-amazon-orange text-amazon-navy hover:bg-amazon-gold font-bold text-center text-xs transition flex items-center justify-center cursor-pointer shadow">
        <i data-lucide="map-pin" class="w-4 h-4 mr-1.5"></i> Track Delivery Status
      </a>
      <button onclick="window.print();" class="w-full sm:w-auto px-6 py-2.5 rounded-lg bg-amazon-gold hover:bg-amber-600 text-amazon-navy border border-transparent text-xs font-bold transition flex items-center justify-center cursor-pointer">
        <i data-lucide="printer" class="w-4 h-4 mr-1.5"></i> Print Receipt Invoice
      </button>
      <a href="/" class="w-full sm:w-auto px-6 py-2.5 rounded-lg bg-amazon-gold hover:bg-amber-600 text-amazon-navy text-xs font-bold text-center transition flex items-center justify-center">
        Go Back to Market Home
      </a>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
