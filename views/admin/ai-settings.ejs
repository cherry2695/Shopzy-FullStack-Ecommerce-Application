<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-4 py-8 flex-grow flex flex-col md:flex-row gap-8 select-none animate-fade-in">
  
  <!-- LEFT RAIL ADMIN SIDEBAR MENU -->
  <aside class="w-full md:w-64 flex-shrink-0 bg-white border border-gray-205 rounded-2xl p-5 shadow-sm md:space-y-4 h-max sticky top-28 text-xs font-semibold">
    <div class="border-b border-gray-100 pb-3 mb-2">
      <h3 class="font-extrabold text-gray-950 uppercase tracking-widest text-[10px] flex items-center"><i data-lucide="shield-alert" class="w-4 h-4 mr-1.5 text-amazon-orange"></i> Shopzy Command Deck</h3>
    </div>

    <nav class="grid grid-cols-2 sm:grid-cols-5 md:flex md:flex-col gap-2 md:space-y-1 text-gray-650">
      <a href="/admin" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-905 transition">
        <i data-lucide="layout-dashboard" class="w-4 h-4 text-gray-400"></i>
        <span>Overview & Reports</span>
      </a>

      <a href="/admin/orders" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition">
        <i data-lucide="shopping-bag" class="w-4 h-4 text-gray-400"></i>
        <span>Manage Orders</span>
      </a>

      <a href="/admin/products" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition">
        <i data-lucide="box" class="w-4 h-4 text-gray-400"></i>
        <span>Manage Products</span>
      </a>

      <a href="/admin/coupons" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition">
        <i data-lucide="ticket" class="w-4 h-4 text-gray-400"></i>
        <span>Promotional Coupons</span>
      </a>

      <a href="/admin/messages" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition">
        <i data-lucide="mail" class="w-4 h-4 text-gray-400"></i>
        <span>Support Messages</span>
      </a>

      <a href="/admin/ai-settings" class="flex items-center space-x-2.5 p-2.5 rounded-lg bg-amazon-orange/10 text-amazon-orange transition">
        <i data-lucide="bot" class="w-4 h-4 text-amazon-orange"></i>
        <span>AI Assistant Settings</span>
      </a>
    </nav>
  </aside>

  <!-- RIGHT PANELS CONTENT SECTION -->
  <section class="flex-grow space-y-8">
    <div class="bg-white border rounded-2xl p-6 shadow-sm border-gray-205">
      <div class="flex items-center justify-between border-b pb-4 mb-6">
        <div class="flex items-center space-x-2.5">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 shadow-sm">
            <i data-lucide="bot" class="w-5 h-5"></i>
          </div>
          <div>
            <h1 class="text-xl font-bold font-display text-gray-950">Shopzy AI Assistant Settings</h1>
            <p class="text-xs text-gray-400">Tailor welcome greetings, quick suggested questions, FAQ knowledge databases, and active catalog recommendation behaviors.</p>
          </div>
        </div>
      </div>

      <!-- Toast Alerts for changes feedback -->
      <% if (typeof successMsg !== 'undefined' && successMsg) { %>
        <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 flex items-center space-x-2 text-xs font-semibold animate-bounce-short">
          <i data-lucide="check-circle" class="w-4 h-4 text-emerald-500"></i>
          <span><%= successMsg %></span>
        </div>
      <% } %>
      <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
        <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 flex items-center space-x-2 text-xs font-semibold">
          <i data-lucide="alert-triangle" class="w-4 h-4 text-red-500"></i>
          <span><%= errorMsg %></span>
        </div>
      <% } %>

      <form action="/admin/ai-settings/update" method="POST" class="space-y-6 text-xs select-none">
        
        <!-- Welcome Messages -->
        <div class="space-y-2">
          <label class="block font-bold text-gray-750 uppercase tracking-wider text-[10px]">Welcome Greeting Message</label>
          <p class="text-[11px] text-gray-450">This message is rendered when the user opens the dialogue widget for the first time.</p>
          <textarea 
            name="welcomeMessage" 
            required 
            rows="3" 
            class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-xl px-3 py-2.5 font-medium text-slate-800 focus:outline-none focus:bg-white text-xs"
          ><%= setting ? setting.welcomeMessage : '' %></textarea>
        </div>

        <!-- Co-separated Quick Suggested Actions -->
        <div class="space-y-2">
          <label class="block font-bold text-gray-750 uppercase tracking-wider text-[10px]">Quick Suggested Questions (Comma Separated)</label>
          <p class="text-[11px] text-gray-450">Define suggested triggers displayed beneath the message thread, separated by commas.</p>
          <input 
            type="text" 
            name="suggestedQuestionsRaw" 
            value="<%= setting ? setting.suggestedQuestions.join(', ') : '' %>"
            class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-xl px-3 py-2.5 font-medium text-slate-800 focus:outline-none focus:bg-white"
            placeholder="e.g. Find laptops, Compare Headphones, Track order"
          />
        </div>

        <!-- AI Product recommendation rules -->
        <div class="space-y-2">
          <label class="block font-bold text-gray-750 uppercase tracking-wider text-[10px]">Product Recommendation Rules & Instructions</label>
          <p class="text-[11px] text-gray-450">Set rules on what products to pair or pitch when users discuss specific gadgets or categories.</p>
          <textarea 
            name="recommendationRules" 
            rows="3" 
            class="w-full bg-slate-50 border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-xl px-3 py-2.5 font-medium text-slate-800 focus:outline-none focus:bg-white text-xs"
            placeholder="e.g. If browsing audio gadgets, always pitches custom headphone stands."
          ><%= setting ? setting.recommendationRules : '' %></textarea>
        </div>

        <!-- FAQ Knowledge Base Additions -->
        <div class="space-y-3">
          <div class="flex items-center justify-between border-b pb-2">
            <label class="block font-black text-slate-800 uppercase tracking-wider text-[10px] flex items-center">
              <i data-lucide="book-open" class="w-4 h-4 mr-1 text-slate-500"></i> Interactive FAQ Knowledge Base
            </label>
            <button type="button" id="add-faq-btn" class="px-2.5 py-1 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg flex items-center transition">
              <i data-lucide="plus" class="w-3.5 h-3.5 mr-1"></i> Add FAQ Row
            </button>
          </div>
          <p class="text-[11px] text-gray-450 mb-3">Feed custom guidelines or policies (returns, warranties, payments) directly to the shopping expert.</p>

          <!-- Dynamic FAQs container -->
          <div id="faqs-list-container" class="space-y-3">
            <% if (setting && setting.faqs && setting.faqs.length > 0) { %>
              <% setting.faqs.forEach((faq, index) => { %>
                <div class="faq-row bg-slate-50 border border-slate-200 p-4 rounded-xl flex flex-col md:flex-row gap-3 items-start relative select-none">
                  <div class="flex-1 w-full space-y-2">
                    <input 
                      type="text" 
                      name="faqQuestions" 
                      value="<%= faq.question %>" 
                      placeholder="Frequently Asked Question Topic" 
                      required
                      class="w-full bg-white border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-3 py-1.5 font-semibold text-slate-800 focus:outline-none"
                    />
                    <textarea 
                      name="faqAnswers" 
                      rows="2" 
                      placeholder="Factual context answers matching topic" 
                      required
                      class="w-full bg-white border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-3 py-1.5 font-medium text-slate-700 focus:outline-none text-xs"
                    ><%= faq.answer %></textarea>
                  </div>
                  <button type="button" onclick="removeFaqRow(this)" class="p-1 px-2.5 bg-red-50 hover:bg-red-100 text-red-650 font-bold border border-red-200 rounded-lg flex items-center transition h-10 mt-0.5" title="Remove FAQ row">
                    <i data-lucide="trash-2" class="w-4 h-4 text-red-600"></i>
                  </button>
                </div>
              <% }) %>
            <% } else { %>
              <!-- Default row fallback -->
              <div class="faq-row bg-slate-50 border border-slate-200 p-4 rounded-xl flex flex-col md:flex-row gap-4 items-start select-none">
                <div class="flex-1 w-full space-y-2">
                  <input 
                    type="text" 
                    name="faqQuestions" 
                    placeholder="e.g. Return Policy" 
                    required
                    class="w-full bg-white border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-3 py-1.5 font-semibold text-slate-800 focus:outline-none"
                  />
                  <textarea 
                    name="faqAnswers" 
                    rows="2" 
                    placeholder="We accept physical items return within 30 days of delivery..." 
                    required
                    class="w-full bg-white border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-3 py-1.5 font-medium text-slate-700 focus:outline-none text-xs"
                  ></textarea>
                </div>
                <button type="button" onclick="removeFaqRow(this)" class="p-1 px-2.5 bg-red-50 hover:bg-red-100 text-red-650 font-bold border border-red-200 rounded-lg flex items-center transition h-10 mt-0.5" title="Remove FAQ row">
                  <i data-lucide="trash-2" class="w-4 h-4 text-red-600"></i>
                </button>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Submit Button -->
        <div class="border-t pt-5 flex justify-end">
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-6 rounded-xl shadow-md transition duration-200 flex items-center">
            <i data-lucide="save" class="w-4 h-4 mr-1.5"></i> Synchronize AI Parameters
          </button>
        </div>

      </form>
    </div>
  </section>
</main>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const addFaqBtn = document.getElementById('add-faq-btn');
    const faqsContainer = document.getElementById('faqs-list-container');

    // Add list row dynamically
    addFaqBtn.addEventListener('click', () => {
      const row = document.createElement('div');
      row.className = "faq-row bg-slate-50 border border-slate-200 p-4 rounded-xl flex flex-col md:flex-row gap-3 items-start relative select-none animate-fade-in";
      row.innerHTML = `
        <div class="flex-1 w-full space-y-2">
          <input 
            type="text" 
            name="faqQuestions" 
            placeholder="Frequently Asked Question Topic" 
            required
            class="w-full bg-white border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-3 py-1.5 font-semibold text-slate-800' focus:outline-none"
          />
          <textarea 
            name="faqAnswers" 
            rows="2" 
            placeholder="Factual context answers matching topic" 
            required
            class="w-full bg-white border border-slate-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-3 py-1.5 font-medium text-slate-700 focus:outline-none text-xs"
          ></textarea>
        </div>
        <button type="button" onclick="removeFaqRow(this)" class="p-1 px-2.5 bg-red-50 hover:bg-red-100 text-red-650 font-bold border border-red-200 rounded-lg flex items-center transition h-10 mt-0.5">
          <i data-lucide="trash-2" class="w-4 h-4 text-red-600"></i>
        </button>
      `;
      faqsContainer.appendChild(row);
      if (typeof lucide !== 'undefined') lucide.createIcons();
    });
  });

  // Remove list row
  function removeFaqRow(button) {
    const row = button.closest('.faq-row');
    row.remove();
  }
</script>

<%- include('../partials/footer') %>
