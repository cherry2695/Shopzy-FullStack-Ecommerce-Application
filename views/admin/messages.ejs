<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-4 py-8 flex-grow flex flex-col md:flex-row gap-8 select-none">
  
  <!-- LEFT RAIL -->
  <aside class="w-full md:w-64 flex-shrink-0 bg-white border border-gray-205 rounded-2xl p-5 shadow-sm md:space-y-4 h-max sticky top-28 text-xs font-semibold">
    <div class="border-b border-gray-100 pb-3 mb-2">
      <h3 class="font-extrabold text-gray-905 uppercase tracking-widest text-[10px] flex items-center"><i data-lucide="shield-alert" class="w-4 h-4 mr-1.5 text-amazon-orange"></i> Shopzy Command Deck</h3>
    </div>

    <nav class="grid grid-cols-2 sm:grid-cols-5 md:flex md:flex-col gap-2 md:space-y-1 text-gray-655 font-semibold text-xs animate-fade-in">
      <a href="/admin" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-901 transition">
        <i data-lucide="layout-dashboard" class="w-4 h-4 text-gray-400"></i>
        <span>Overview & Reports</span>
      </a>

      <a href="/admin/orders" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-911 transition">
        <i data-lucide="shopping-bag" class="w-4 h-4 text-gray-400"></i>
        <span>Manage Orders</span>
      </a>

      <a href="/admin/products" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition">
        <i data-lucide="box" class="w-4 h-4 text-gray-400"></i>
        <span>Manage Products</span>
      </a>

      <a href="/admin/coupons" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition">
        <i data-lucide="ticket" class="w-4 h-4 text-gray-400"></i>
        <span>Promotional Coupons</span>
      </a>

      <a href="/admin/messages" class="flex items-center space-x-2.5 p-2.5 rounded-lg bg-amazon-orange/10 text-amazon-orange transition">
        <i data-lucide="mail" class="w-4 h-4"></i>
        <span>Support Messages</span>
      </a>
    </nav>
  </aside>

  <!-- RIGHT EDIT PANEL -->
  <section class="flex-grow space-y-6">
    <div class="border-b border-gray-200 pb-3 flex justify-between items-center">
      <h2 class="text-xl font-bold font-display text-gray-950 flex items-center">
        <span class="h-5 w-1.5 bg-amazon-orange rounded mr-2"></span> Customer Tickets Desk
      </h2>
      <span class="text-xs text-gray-500 font-semibold font-mono">Unresolved: <strong><%= messages.length %> queries registered</strong></span>
    </div>

    <% if (messages.length === 0) { %>
      <div class="bg-white border rounded-2xl p-16 text-center text-gray-400 select-none shadow-sm text-xs font-semibold">
        No helpdesk tickets pending. Beautiful SLAs!
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% messages.forEach(msg => { %>
          <div class="bg-white border rounded-2xl p-5 shadow-sm space-y-4">
            
            <div class="flex flex-wrap items-center justify-between gap-4 border-b border-gray-100 pb-3 text-xs font-semibold text-gray-655 font-sans leading-none">
              <div class="flex items-center space-x-2.5">
                <span class="h-2 w-2 rounded-full bg-red-500 animate-pulse"></span>
                <p>Raised by: <strong class="text-gray-950"><%= msg.name %></strong> (<code class="font-mono text-[10px] text-gray-400"><%= msg.email %></code>)</p>
              </div>

              <div class="flex gap-2">
                <span class="bg-gray-100 text-gray-650 text-[9px] font-bold py-1 px-2.5 rounded border"><%= msg.category %></span>
              </div>
            </div>

            <div class="text-xs space-y-1 text-gray-700">
              <p class="font-bold text-gray-950 text-sm leading-snug">Topic: <%= msg.subject %></p>
              <p class="leading-relaxed bg-gray-55/70 border border-gray-100 rounded-lg p-3.5 mt-2.5 font-sans"><%= msg.message %></p>
            </div>

            <!-- Delete action row -->
            <div class="pt-3 border-t border-gray-100 flex justify-between items-center text-xs font-semibold">
              <p class="text-[10px] text-gray-400 font-mono">TICKET SUBMITTED: <%= new Date(msg.createdAt).toLocaleDateString() %></p>
              
              <a href="/admin/messages/delete/<%= msg.id || msg._id %>" onclick="return confirm('Dismiss and resolve support ticket?');" class="inline-flex items-center text-red-500 hover:underline">
                <i data-lucide="trash-2" class="w-3.5 h-3.5 mr-1"></i> Resolve Ticket
              </a>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>

  </section>
</main>

<%- include('../partials/footer') %>
