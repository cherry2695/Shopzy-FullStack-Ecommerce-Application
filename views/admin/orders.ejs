<%- include('../partials/header') %>

<main class="max-w-7xl mx-auto px-4 py-8 flex-grow flex flex-col md:flex-row gap-8 select-none">
  
  <!-- LEFT RAIL MENU -->
  <aside class="w-full md:w-64 flex-shrink-0 bg-white border border-gray-205 rounded-2xl p-5 shadow-sm md:space-y-4 h-max sticky top-28 text-xs font-semibold">
    <div class="border-b border-gray-100 pb-3 mb-2">
      <h3 class="font-extrabold text-gray-950 uppercase tracking-widest text-[10px] flex items-center"><i data-lucide="shield-alert" class="w-4 h-4 mr-1.5 text-amazon-orange"></i> Shopzy Command Deck</h3>
    </div>

    <nav class="grid grid-cols-2 sm:grid-cols-5 md:flex md:flex-col gap-2 md:space-y-1 text-gray-650">
      <a href="/admin" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-901 transition">
        <i data-lucide="layout-dashboard" class="w-4 h-4 text-gray-400"></i>
        <span>Overview & Reports</span>
      </a>

      <a href="/admin/orders" class="flex items-center space-x-2.5 p-2.5 rounded-lg bg-amazon-orange/10 text-amazon-orange transition">
        <i data-lucide="shopping-bag" class="w-4 h-4"></i>
        <span>Manage Orders</span>
      </a>

      <a href="/admin/products" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-909 transition">
        <i data-lucide="box" class="w-4 h-4 text-gray-400"></i>
        <span>Manage Products</span>
      </a>

      <a href="/admin/coupons" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition">
        <i data-lucide="ticket" class="w-4 h-4 text-gray-400"></i>
        <span>Promotional Coupons</span>
      </a>

      <a href="/admin/messages" class="flex items-center space-x-2.5 p-2.5 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition">
        <i data-lucide="mail" class="w-4 h-4 text-gray-400"></i>
        <span>Support Messages</span>
      </a>
    </nav>
  </aside>

  <!-- RIGHT EDITABLE LISTINGS -->
  <section class="flex-grow space-y-6">
    <div class="border-b border-gray-200 pb-3 flex justify-between items-center">
      <h2 class="text-xl font-bold font-display text-gray-950 flex items-center">
        <span class="h-5 w-1.5 bg-amazon-orange rounded mr-2"></span> Logistics & Deliveries Order Desk
      </h2>
      <span class="text-xs text-gray-500 font-semibold font-mono">Found: <strong><%= orders.length %> record queues</strong></span>
    </div>

    <% if (orders.length === 0) { %>
      <div class="bg-white rounded-2xl border p-12 text-center text-gray-400">
        No shipment orders located in the database logs.
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% orders.forEach(o => { %>
          <div class="bg-white border rounded-2xl p-5 shadow-sm space-y-4">
            
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 border-b border-gray-100 pb-3 text-xs font-semibold text-gray-650">
              <div class="flex flex-wrap gap-4 sm:gap-6">
                <p>REF ID: <strong class="font-mono text-gray-950">#<%= o.orderId %></strong></p>
                <span class="text-gray-300">|</span>
                <p>Recipent: <strong class="text-gray-900"><%= o.shippingAddress.fullName %></strong></p>
                <span class="text-gray-300">|</span>
                <p>Bill Value: <strong class="font-mono text-green-600">Rs. <%= o.pricing.total %></strong></p>
              </div>

              <!-- Live status badge indicator -->
              <div>
                <% if (o.orderStatus === 'Pending') { %>
                  <span class="bg-amber-100 text-amber-805 text-[9px] font-black tracking-wider px-2 py-0.5 rounded-full uppercase">Pending Check</span>
                <% } else if (o.orderStatus === 'Delivered') { %>
                  <span class="bg-emerald-110 bg-green-100 text-green-800 text-[9px] font-black tracking-wider px-2 py-0.5 rounded-full uppercase">Distributed Success</span>
                <% } else { %>
                  <span class="bg-blue-100 text-blue-800 text-[9px] font-black tracking-wider px-2 py-0.5 rounded-full uppercase"><%= o.orderStatus %></span>
                <% } %>
              </div>
            </div>

            <!-- Items summary listings -->
            <div class="text-xs space-y-1.5 text-gray-650">
              <% o.items.forEach(itm => { %>
                <div class="flex items-center justify-between">
                  <span class="truncate block max-w-lg text-gray-800 font-semibold"><%= itm.title %></span>
                  <span class="font-mono font-bold">x<%= itm.quantity %></span>
                </div>
              <% }) %>
            </div>

            <!-- Status updater form -->
            <div class="pt-3 border-t border-gray-100 flex flex-wrap justify-between items-center gap-4 text-xs font-semibold">
              <p class="text-gray-400 font-mono text-[10px]">CREATED: <%= new Date(o.createdAt).toLocaleDateString() %></p>
              
              <form action="/admin/orders/update/<%= o.orderId %>" method="POST" class="flex gap-2 items-center">
                <label class="text-gray-500 font-bold">Shift Status:</label>
                <select name="status" class="bg-gray-50 text-gray-805 border border-gray-200 rounded p-1.5 cursor-pointer">
                  <% ['Pending', 'Confirmed', 'Packed', 'Shipped', 'Out For Delivery', 'Delivered', 'Cancelled'].forEach(st => { %>
                    <option value="<%= st %>" <%= o.orderStatus === st ? 'selected' : '' %>><%= st %></option>
                  <% }) %>
                </select>
                <button type="submit" class="bg-amazon-gold hover:bg-amazon-orange text-amazon-navy font-black py-1.5 px-3 rounded text-[11px] uppercase tracking-wider cursor-pointer">
                  Mutate
                </button>
              </form>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/footer') %>
