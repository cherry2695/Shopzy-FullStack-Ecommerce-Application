<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 py-8 flex-grow select-none">
  
  <div class="border-b border-gray-200 pb-4 mb-8">
    <h1 class="text-3xl font-bold font-display text-gray-950 tracking-tight flex items-center">
      <i data-lucide="package-search" class="w-7 h-7 mr-2 text-amazon-gold"></i> Your Orders Registry
    </h1>
    <p class="text-xs text-gray-500">Examine invoice histories, retrieve reference IDs, and trigger real-time delivery trackers.</p>
  </div>

  <% if (orders.length === 0) { %>
    <!-- Empty orders listings -->
    <div class="bg-white border border-gray-200 rounded-2xl p-16 shadow-sm text-center">
      <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-indigo-100 text-indigo-600 mb-4">
        <i data-lucide="package" class="w-6 h-6"></i>
      </div>
      <h3 class="text-lg font-bold text-gray-905 mb-1">No Orders Registry Found</h3>
      <p class="text-xs text-gray-500 max-w-sm mx-auto mb-6">Looks like you haven't processed any purchases yet on our platform.</p>
      <a href="/products" class="bg-amazon-gold text-amazon-navy text-xs font-black py-2.5 px-6 rounded-lg hover:bg-amazon-orange transition shadow">
        Browse Products Catalog
      </a>
    </div>
  <% } else { %>
    <!-- Orders grid compact row cards -->
    <div class="space-y-6">
      <% orders.forEach(order => { %>
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden flex flex-col justify-between">
          
          <!-- Card Header details -->
          <div class="bg-gray-50/75 border-b border-gray-200 p-4 sm:p-5 flex flex-wrap justify-between items-center gap-4 text-xs font-semibold text-gray-650">
            <div class="flex flex-wrap gap-4 sm:gap-8">
              <div>
                <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider leading-none">ORDER PLACED</p>
                <p class="text-gray-901 mt-1"><%= new Date(order.createdAt).toLocaleDateString() %></p>
              </div>
              <div>
                <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider leading-none">TOTAL OUTSTANDING</p>
                <p class="text-gray-901 mt-1 font-mono font-bold">Rs. <%= order.pricing.total %></p>
              </div>
              <div>
                <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider leading-none">SHIP TO</p>
                <p class="text-amazon-gold hover:underline mt-1 cursor-pointer" title="<%= order.shippingAddress.addressLine1 %>"><%= order.shippingAddress.fullName %></p>
              </div>
            </div>

            <div class="text-right sm:text-right">
              <p class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider leading-none">ORDER REFERENCE ID</p>
              <p class="font-mono text-gray-905 mt-1">#<%= order.orderId %></p>
            </div>
          </div>

          <!-- Card content products mapping -->
          <div class="p-5 divide-y divide-gray-105">
            <% order.items.forEach(item => { %>
              <div class="py-4 first:pt-0 last:pb-0 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex items-center space-x-4">
                  <img src="<%= item.image %>" class="w-12 h-12 object-cover border rounded-lg bg-gray-50" referrerPolicy="no-referrer" />
                  <div class="min-w-0">
                    <p class="font-bold text-gray-950 text-sm truncate max-w-md"><%= item.title %></p>
                    <p class="text-xs text-gray-500">QTY: <%= item.quantity %> x Rs. <%= item.price %></p>
                  </div>
                </div>

                <!-- Custom delivery badges mapping -->
                <div class="flex items-center space-x-3 text-xs">
                  <!-- Match status color -->
                  <% if (order.orderStatus === 'Pending') { %>
                    <span class="bg-amber-50 text-amber-800 border border-amber-205 py-1 px-3 rounded-full font-black text-[10px] uppercase tracking-wider">Pending Confirm</span>
                  <% } else if (order.orderStatus === 'Shipped' || order.orderStatus === 'Packed') { %>
                    <span class="bg-blue-50 text-blue-805 border border-blue-200 py-1 px-3 rounded-full font-black text-[10px] uppercase tracking-wider">En Route Logistics</span>
                  <% } else if (order.orderStatus === 'Delivered') { %>
                    <span class="bg-emerald-50 text-emerald-800 border border-emerald-205 py-1 px-3 rounded-full font-black text-[10px] uppercase tracking-wider">Delivered Success</span>
                  <% } else { %>
                    <span class="bg-red-50 text-red-650 border border-red-200 py-1 px-3 rounded-full font-black text-[10px] uppercase tracking-wider"><%= order.orderStatus %></span>
                  <% } %>

                  <a href="/orders/track/<%= order.orderId %>" class="px-4 py-2 bg-amazon-gold hover:bg-amber-600 text-amazon-navy font-bold rounded-lg transition text-xs shadow-inner flex items-center">
                    <i data-lucide="map-pin" class="w-3.5 h-3.5 mr-1 text-amazon-gold"></i> Track Logistics
                  </a>
                </div>
              </div>
            <% }) %>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>

</main>

<%- include('partials/footer') %>
